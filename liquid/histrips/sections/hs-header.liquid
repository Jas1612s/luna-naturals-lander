<header class="hs-header" id="hs-header">
  <div class="hs-header-inner">
    <a href="/" class="hs-logo">
      <img src="{{ 'histrips-logo.svg' | asset_url }}" alt="HiStrips" width="100" height="32">
    </a>

    <nav class="hs-nav">
      <a href="/collections/all">Products</a>
      <a href="/pages/about">About</a>
      <a href="/pages/reviews">Reviews</a>
      <a href="/pages/science">Science</a>
    </nav>

    <div class="hs-header-right">
      <div class="hs-pill-new">NEW</div>
      <a href="/cart" class="hs-cart-btn" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "HiStrips Header",
  "settings": []
}
{% endschema %}
