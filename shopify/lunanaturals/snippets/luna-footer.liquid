<footer class="luna-footer">
  <div class="luna-footer__inner">
    <!-- 4-column grid -->
    <div class="luna-footer__grid">
      <!-- Column 1: Email Signup -->
      <div class="luna-footer__signup">
        <p class="luna-footer__signup-title">Get 10% Off Your First Order</p>
        <form class="luna-footer__signup-form" action="/contact#contact_form" method="post" accept-charset="UTF-8">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="&#x2713;">
          <input
            type="email"
            name="contact[email]"
            placeholder="Email address"
            class="luna-footer__signup-input"
            autocomplete="email"
            required
          >
          <button type="submit" class="luna-footer__signup-btn" aria-label="Submit email">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
        </form>
      </div>

      <!-- Column 2: Learn -->
      <div class="luna-footer__col">
        <h3 class="luna-footer__col-title gr-display">Learn</h3>
        <ul class="luna-footer__links">
          <li><a href="#" class="luna-footer__link">Our Science</a></li>
          <li><a href="#" class="luna-footer__link">How It Works</a></li>
          <li><a href="#" class="luna-footer__link">Our Story</a></li>
          <li><a href="#" class="luna-footer__link">FAQs</a></li>
        </ul>
      </div>

      <!-- Column 3: Connect -->
      <div class="luna-footer__col">
        <h3 class="luna-footer__col-title gr-display">Connect</h3>
        <ul class="luna-footer__links">
          <li><a href="#" class="luna-footer__link">Contact Us</a></li>
          <li><a href="#" class="luna-footer__link">Refer a Friend</a></li>
          <li><a href="#" class="luna-footer__link">Partners &amp; Influencers</a></li>
          <li><a href="#" class="luna-footer__link">Press Inquiries</a></li>
          <li><a href="#" class="luna-footer__link">Returns &amp; Exchanges</a></li>
        </ul>
      </div>

      <!-- Column 4: Shop -->
      <div class="luna-footer__col">
        <h3 class="luna-footer__col-title gr-display">Shop</h3>
        <ul class="luna-footer__links">
          <li><a href="#" class="luna-footer__link">Adults Patches (90 ct)</a></li>
          <li><a href="#" class="luna-footer__link">Kids Patches (90 ct)</a></li>
          <li><a href="#" class="luna-footer__link">Bundle &amp; Save</a></li>
        </ul>
      </div>
    </div>

    <!-- Logo + Social Row -->
    <div class="luna-footer__brand-row">
      <img
        src="{{ 'luna-naturals-logo-cropped.webp' | asset_url }}"
        alt="{{ shop.name }}"
        class="luna-footer__brand-logo"
        width="160"
        height="48"
      >
      <div class="luna-footer__social">
        {% if settings.social_instagram != blank %}
          <a href="{{ settings.social_instagram }}" aria-label="Instagram">
        {% else %}
          <a href="#" aria-label="Instagram">
        {% endif %}
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="white" stroke-width="1.5" />
              <circle cx="12" cy="12" r="4.5" stroke="white" stroke-width="1.5" />
              <circle cx="17.5" cy="6.5" r="1" fill="white" />
            </svg>
          </a>

        {% if settings.social_tiktok != blank %}
          <a href="{{ settings.social_tiktok }}" aria-label="TikTok">
        {% else %}
          <a href="#" aria-label="TikTok">
        {% endif %}
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.73a8.18 8.18 0 0 0 4.78 1.53V6.79a4.85 4.85 0 0 1-1.01-.1Z" fill="white" />
            </svg>
          </a>

        {% if settings.social_facebook != blank %}
          <a href="{{ settings.social_facebook }}" aria-label="Facebook">
        {% else %}
          <a href="#" aria-label="Facebook">
        {% endif %}
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="luna-footer__disclaimer">
      <div class="luna-footer__disclaimer-box">
        *Our patches are not intended to diagnose, treat, cure, or prevent any disease. Results may vary. Consult your healthcare provider before use if you have sensitive skin or allergies.
      </div>
    </div>

    <!-- Copyright Bar -->
    <div class="luna-footer__copyright-bar">
      <span>&copy; Copyright {{ 'now' | date: '%Y' }}, {{ shop.name }}</span>
      <div class="luna-footer__policy-links">
        <a href="/policies/refund-policy">Refund Policy</a>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms Of Service</a>
        <a href="/policies/shipping-policy">Shipping Policy</a>
        <a href="#">Accessibility</a>
      </div>
    </div>
  </div>
</footer>
