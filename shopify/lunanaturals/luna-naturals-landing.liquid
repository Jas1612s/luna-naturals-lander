  <!-- ================================================================
       JAVASCRIPT — Countdown, Hero Carousel, Rotating Words
       ================================================================ -->
  <script>
    (function() {
      "use strict";

      /* ---- Countdown Timer ---- */
      var hrs = 3, min = 0, sec = 0;
      var hrsEl = document.getElementById("gr-hrs");
      var minEl = document.getElementById("gr-min");
      var secEl = document.getElementById("gr-sec");

      function pad(n) {
        return String(n).padStart(2, "0");
      }

      setInterval(function() {
        sec -= 1;
        if (sec < 0) { sec = 59; min -= 1; }
        if (min < 0) { min = 59; hrs -= 1; }
        if (hrs < 0) { hrs = 0; min = 0; sec = 0; }
        hrsEl.textContent = pad(hrs);
        minEl.textContent = pad(min);
        secEl.textContent = pad(sec);
      }, 1000);

      /* ---- Hero Image Carousel ---- */
      var slides = document.querySelectorAll(".gr-hero-slide");
      var dots = document.querySelectorAll(".gr-hero-dot");
      var activeSlide = 0;
      var totalSlides = slides.length;

      function goToSlide(index) {
        slides[activeSlide].classList.remove("active");
        slides[activeSlide].classList.add("inactive");
        dots[activeSlide].classList.remove("active");

        activeSlide = index;

        slides[activeSlide].classList.remove("inactive");
        slides[activeSlide].classList.add("active");
        dots[activeSlide].classList.add("active");
      }

      // Auto-advance every 5 seconds
      var carouselInterval = setInterval(function() {
        goToSlide((activeSlide + 1) % totalSlides);
      }, 5000);

      // Dot click handlers
      dots.forEach(function(dot, i) {
        dot.addEventListener("click", function() {
          clearInterval(carouselInterval);
          goToSlide(i);
          // Restart auto-advance
          carouselInterval = setInterval(function() {
            goToSlide((activeSlide + 1) % totalSlides);
          }, 5000);
        });
      });

      /* ---- Rotating Words (Tick / Itch) ---- */
      var rotatingWords = ["Tick", "Itch"];
      var wordIndex = 0;
      var wordEl = document.getElementById("gr-rotating-word");

      setInterval(function() {
        // Fade out
        wordEl.classList.remove("visible");
        wordEl.classList.add("hidden");

        setTimeout(function() {
          wordIndex = (wordIndex + 1) % rotatingWords.length;
          wordEl.textContent = rotatingWords[wordIndex];
          // Fade in
          wordEl.classList.remove("hidden");
          wordEl.classList.add("visible");
        }, 300);
      }, 5000);

    })();
  </script>

