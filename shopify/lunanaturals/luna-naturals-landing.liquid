<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Plant-powered mosquito protection for the whole family. DEET-free, pediatrician-reviewed patches that last up to 12 hours. Safe for kids and adults." />
  <title>Luna Naturals | Mosquito Repellent Patches</title>

  <!-- Fonts: Work Sans (body) + Retail Display (display headings) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    /* ================================================================
       FONT FACE — Retail Display (display headings)
       ================================================================ */
    @font-face {
      font-family: "Retail Display";
      src: url("{{ 'retail-display.woff' | asset_url }}") format("woff");
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    /* ================================================================
       RESET & BASE
       ================================================================ */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    img {
      max-width: 100%;
      display: block;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    button {
      cursor: pointer;
      font-family: inherit;
    }

    /* ================================================================
       GRUNS ROOT — Design Tokens
       ================================================================ */
    .gruns-root {
      --gr-green: #4A5A2E;
      --gr-green-dark: #2E3A1A;
      --gr-green-deep: rgba(46, 58, 26, 0.97);
      --gr-green-mid: #647A3E;
      --gr-yellow: #D4A020;
      --gr-cream: #F5F0E6;
      --gr-cream-light: #FAF7F0;
      --gr-cream-warm: #EDE6D6;
      --gr-white: #FDFAF6;
      --gr-dark: #1C1B10;
      --gr-sage: #586B3A;
      --gr-accent: #D4A020;
      --gr-accent-light: #FDF3D8;
      --gr-gold: #D4A020;
      --gr-sky: #A8D5E2;
      --gr-text-white: rgba(245, 240, 230, 0.97);
      --gr-text-dark: rgba(28, 27, 16, 0.95);
      --gr-accent-text: #1C1B10;

      font-family: "Work Sans", "Helvetica Neue", Helvetica, Arial, sans-serif;
      color: var(--gr-dark);
      background-color: var(--gr-cream);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      min-height: 100%;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }

    @media (prefers-reduced-motion: reduce) {
      .gruns-root {
        scroll-behavior: auto;
      }
    }

    /* Subtle linen texture on cream backgrounds */
    .gruns-root {
      background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.018'/%3E%3C/svg%3E");
    }

    /* Display font class */
    .gr-display {
      font-family: "Retail Display", "Work Sans", sans-serif;
    }

    /* Scrollbar hide */
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
      scroll-behavior: auto;
      -webkit-overflow-scrolling: touch;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }

    /* ================================================================
       KEYFRAME ANIMATIONS
       ================================================================ */

    /* Glow pulse on badge */
    @keyframes gr-glow-pulse {
      0%, 100% {
        box-shadow: 0 0 20px rgba(212,160,32,0.6), 0 0 40px rgba(212,160,32,0.3);
      }
      50% {
        box-shadow: 0 0 30px rgba(212,160,32,0.8), 0 0 60px rgba(212,160,32,0.4), 0 0 80px rgba(212,160,32,0.2);
      }
    }

    /* Badge wobble */
    @keyframes gr-badge-wobble {
      0%, 100% { transform: rotate(6deg) scale(1); }
      25% { transform: rotate(-4deg) scale(1.05); }
      50% { transform: rotate(8deg) scale(1); }
      75% { transform: rotate(-2deg) scale(1.03); }
    }

    /* Float */
    @keyframes gr-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    /* Marquee scroll */
    @keyframes gr-marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* Fade up */
    @keyframes gr-fade-up {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Benefit bounce */
    @keyframes gr-benefit-bounce {
      0%, 100% { transform: translateY(0) scale(1); }
      15% { transform: translateY(-18px) scale(1.02); }
      30% { transform: translateY(0) scale(1); }
      45% { transform: translateY(-10px) scale(1.01); }
      60% { transform: translateY(0) scale(1); }
    }

    /* Pulse for product words */
    @keyframes gr-pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.08); }
    }

    /* ================================================================
       MARQUEE TRACK
       ================================================================ */
    .gr-marquee-track {
      display: flex;
      animation: gr-marquee 25s linear infinite;
    }

    .gr-marquee-track:hover {
      animation-play-state: paused;
    }

    /* Fade up utility */
    .gr-fade-up {
      animation: gr-fade-up 0.6s ease forwards;
    }

    /* ================================================================
       COMPONENT: NAV — Announcement Bar
       ================================================================ */
    .gr-announcement-bar {
      background-color: var(--gr-accent);
      padding: 12px 16px;
    }

    .gr-announcement-inner {
      max-width: 1440px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
    }

    .gr-announcement-text {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .gr-announcement-title {
      font-size: 14px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      line-height: 1.2;
      color: var(--gr-accent-text);
    }

    .gr-announcement-sub {
      font-size: 12px;
      font-weight: 500;
      line-height: 1.2;
      color: var(--gr-accent-text);
      opacity: 0.7;
    }

    .gr-countdown {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .gr-countdown-sep {
      font-weight: 700;
      font-size: 14px;
      line-height: 1;
      color: var(--gr-accent-text);
      opacity: 0.4;
    }

    .gr-countdown-unit {
      background-color: #ffffff;
      color: var(--gr-dark);
      border-radius: 6px;
      padding: 6px 8px;
      min-width: 38px;
      text-align: center;
    }

    .gr-countdown-val {
      font-size: 16px;
      font-weight: 700;
      line-height: 1;
      display: block;
    }

    .gr-countdown-label {
      font-size: 7px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gr-sage);
      display: block;
      margin-top: 2px;
    }

    /* ================================================================
       COMPONENT: NAV — Main Navigation
       ================================================================ */
    .gr-nav {
      background-color: var(--gr-green);
      border-bottom: 1px solid rgba(88, 107, 58, 0.3);
    }

    .gr-nav-inner {
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      align-items: center;
      height: 60px;
    }

    .gr-nav-left {
      display: flex;
      align-items: center;
    }

    .gr-nav-center {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
    }

    .gr-nav-logo {
      height: 40px;
      width: auto;
    }

    .gr-nav-right {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 16px;
    }

    @media (min-width: 768px) {
      .gr-nav-logo {
        height: 48px;
      }
    }

    /* Sticky header */
    .gr-header {
      position: sticky;
      top: 0;
      z-index: 50;
    }

    /* ================================================================
       COMPONENT: HERO SECTION
       ================================================================ */
    .gr-hero {
      position: relative;
      overflow: hidden;
      min-height: 668px;
    }

    .gr-hero-inner {
      display: flex;
      flex-direction: column;
      min-height: 668px;
    }

    @media (min-width: 768px) {
      .gr-hero-inner {
        flex-direction: row;
      }
    }

    /* Hero text side */
    .gr-hero-text {
      position: relative;
      z-index: 10;
      display: flex;
      flex: 1;
      align-items: center;
      background: linear-gradient(135deg, #2E3A1A 0%, #4A5A2E 40%, #647A3E 70%, #F5F0E6 100%);
    }

    .gr-hero-text-content {
      margin: 0 auto;
      max-width: 700px;
      padding: 24px 16px;
    }

    @media (min-width: 768px) {
      .gr-hero-text-content {
        padding: 48px 24px;
      }
    }

    .gr-hero-heading {
      font-family: "Retail Display", "Work Sans", sans-serif;
      margin-bottom: 24px;
      font-size: 44px;
      line-height: 1;
      color: rgba(255,255,255,0.95);
      font-weight: 400;
    }

    @media (min-width: 768px) {
      .gr-hero-heading {
        font-size: 96px;
      }
    }

    .gr-hero-rotating-word {
      display: inline-block;
      color: var(--gr-accent);
      transition: opacity 300ms ease, transform 300ms ease;
    }

    .gr-hero-rotating-word.hidden {
      opacity: 0;
      transform: translateY(12px);
    }

    .gr-hero-rotating-word.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .gr-hero-cta-wrap {
      margin-bottom: 16px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .gr-hero-cta {
      display: inline-block;
      border-radius: 9999px;
      padding: 12px 24px;
      font-size: 14px;
      font-weight: 600;
      background-color: var(--gr-accent);
      color: var(--gr-accent-text);
      transition: opacity 0.2s ease;
    }

    .gr-hero-cta:hover {
      opacity: 0.9;
    }

    @media (min-width: 768px) {
      .gr-hero-cta {
        padding: 12px 32px;
      }
    }

    .gr-hero-stars {
      font-size: 14px;
      font-weight: 500;
      color: var(--gr-accent);
    }

    .gr-hero-subtext {
      font-size: 12px;
      margin-top: 8px;
      font-weight: 500;
      color: var(--gr-dark);
    }

    /* Hero image carousel */
    .gr-hero-carousel {
      position: relative;
      flex: 1;
      overflow: hidden;
      min-height: 340px;
    }

    .gr-hero-slide {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: opacity 500ms ease-in-out;
    }

    .gr-hero-slide.active {
      opacity: 1;
    }

    .gr-hero-slide.inactive {
      opacity: 0;
    }

    /* Dot indicators */
    .gr-hero-dots {
      position: absolute;
      bottom: 16px;
      right: 16px;
      z-index: 10;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .gr-hero-dot {
      height: 10px;
      border-radius: 50%;
      background-color: rgba(255,255,255,0.5);
      border: none;
      padding: 0;
      width: 10px;
      transition: width 300ms ease, background-color 300ms ease, border-radius 300ms ease;
    }

    .gr-hero-dot.active {
      width: 32px;
      border-radius: 9999px;
      background-color: #ffffff;
    }

    /* ================================================================
       COMPONENT: PRESS MARQUEE
       ================================================================ */
    .gr-press {
      position: relative;
      overflow: hidden;
      background-color: var(--gr-cream-light);
      padding: 12px 0;
    }

    .gr-press-label {
      text-align: center;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gr-sage);
      margin-bottom: 12px;
    }

    .gr-press-fade-left {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 64px;
      background: linear-gradient(to right, var(--gr-cream-light), transparent);
      z-index: 10;
      pointer-events: none;
    }

    .gr-press-fade-right {
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 64px;
      background: linear-gradient(to left, var(--gr-cream-light), transparent);
      z-index: 10;
      pointer-events: none;
    }

    .gr-press-logo {
      height: 24px;
      width: auto;
      opacity: 0.6;
      filter: grayscale(100%);
      flex-shrink: 0;
    }

    @media (min-width: 768px) {
      .gr-press-logo {
        height: 28px;
      }
    }

    .gr-press .gr-marquee-track {
      align-items: center;
      gap: 40px;
    }

    @media (min-width: 768px) {
      .gr-press .gr-marquee-track {
        gap: 56px;
      }
    }

    /* ================================================================
       COMPONENT: PRODUCT SHOWCASE
       ================================================================ */
    .gr-showcase {
      background-color: var(--gr-cream-light);
      padding: 56px 16px;
    }

    @media (min-width: 768px) {
      .gr-showcase {
        padding: 80px 16px;
      }
    }

    @media (min-width: 1024px) {
      .gr-showcase {
        padding: 112px 16px;
      }
    }

    .gr-showcase-inner {
      max-width: 512px;
      margin: 0 auto;
    }

    @media (min-width: 1024px) {
      .gr-showcase-inner {
        max-width: 900px;
      }
    }

    /* Title */
    .gr-showcase-title {
      font-family: "Retail Display", "Work Sans", sans-serif;
      font-size: 30px;
      line-height: 1.15;
      color: var(--gr-dark);
      text-align: center;
      max-width: 672px;
      margin: 0 auto;
    }

    @media (min-width: 768px) {
      .gr-showcase-title {
        font-size: 36px;
      }
    }

    @media (min-width: 1024px) {
      .gr-showcase-title {
        font-size: 48px;
      }
    }

    .gr-showcase-title .italic {
      font-style: italic;
    }

    .gr-showcase-title .green {
      color: var(--gr-green);
    }

    .gr-showcase-title .accent {
      color: var(--gr-accent);
    }

    .gr-pulse-word {
      display: inline-block;
      animation: gr-pulse 2.5s ease-in-out infinite;
    }

    .gr-pulse-word:nth-of-type(2) {
      animation-delay: 0.4s;
    }

    .gr-pulse-word:nth-of-type(3) {
      animation-delay: 0.8s;
    }

    .gr-showcase-subtitle {
      margin-top: 16px;
      font-size: 14px;
      color: var(--gr-sage);
      line-height: 1.625;
      text-align: center;
      max-width: 448px;
      margin-left: auto;
      margin-right: auto;
    }

    @media (min-width: 768px) {
      .gr-showcase-subtitle {
        margin-top: 20px;
        font-size: 16px;
      }
    }

    @media (min-width: 1024px) {
      .gr-showcase-subtitle {
        font-size: 18px;
      }
    }

    .gr-showcase-subtitle strong {
      color: var(--gr-dark);
    }

    /* Product image wrapper */
    .gr-showcase-img-wrap {
      position: relative;
      margin-top: 32px;
      border-radius: 16px;
      overflow: hidden;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
      aspect-ratio: 4 / 5;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    @media (min-width: 1024px) {
      .gr-showcase-img-wrap {
        margin-top: 48px;
        max-width: 100%;
        aspect-ratio: 3 / 2;
      }
    }

    .gr-showcase-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* 60% badge */
    .gr-showcase-badge {
      position: absolute;
      bottom: 16px;
      right: 16px;
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background-color: var(--gr-accent);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      box-shadow: 0 0 20px rgba(212,160,32,0.6), 0 0 40px rgba(212,160,32,0.3), 0 0 60px rgba(212,160,32,0.15);
      animation: gr-glow-pulse 2s ease-in-out infinite;
    }

    @media (min-width: 1024px) {
      .gr-showcase-badge {
        width: 96px;
        height: 96px;
      }
    }

    .gr-showcase-badge-sm {
      font-size: 10px;
      font-weight: 700;
      line-height: 1.2;
      color: var(--gr-accent-text);
    }

    @media (min-width: 1024px) {
      .gr-showcase-badge-sm {
        font-size: 12px;
      }
    }

    .gr-showcase-badge-lg {
      font-size: 20px;
      font-weight: 900;
      line-height: 1;
      color: var(--gr-accent-text);
    }

    @media (min-width: 1024px) {
      .gr-showcase-badge-lg {
        font-size: 24px;
      }
    }

    /* Benefits grid */
    .gr-benefits-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px 24px;
      margin-top: 32px;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    @media (min-width: 1024px) {
      .gr-benefits-grid {
        grid-template-columns: repeat(3, 1fr);
        margin-top: 48px;
        max-width: 100%;
      }
    }

    .gr-benefit-item {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .gr-benefit-icon {
      flex-shrink: 0;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background-color: rgba(74, 90, 46, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
    }

    @media (min-width: 1024px) {
      .gr-benefit-icon {
        width: 48px;
        height: 48px;
        font-size: 20px;
      }
    }

    .gr-benefit-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--gr-dark);
      line-height: 1.2;
    }

    @media (min-width: 1024px) {
      .gr-benefit-title {
        font-size: 16px;
      }
    }

    /* Showcase CTA */
    .gr-showcase-cta-wrap {
      max-width: 500px;
      margin: 40px auto 0;
    }

    .gr-showcase-cta {
      display: block;
      width: 100%;
      padding: 16px;
      background-color: var(--gr-accent);
      color: var(--gr-accent-text);
      text-align: center;
      font-weight: 900;
      font-size: 16px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-radius: 12px;
      border: none;
      transition: filter 0.2s ease;
    }

    @media (min-width: 768px) {
      .gr-showcase-cta {
        font-size: 18px;
      }
    }

    .gr-showcase-cta:hover {
      filter: brightness(1.1);
    }

    .gr-showcase-guarantee {
      margin-top: 12px;
      font-size: 14px;
      color: var(--gr-green);
      font-weight: 500;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    .gr-showcase-guarantee svg {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }

    /* ================================================================
       COMPONENT: WAVE DIVIDERS
       ================================================================ */
    .gr-wave-divider {
      width: 100%;
      display: block;
      margin: -1px 0;
      height: clamp(40px, 5vw, 60px);
    }
  </style>
</head>
<body>
<div class="gruns-root">

  <!-- ================================================================
       NAV — Sticky Header
       ================================================================ -->
  <header class="gr-header">
    <!-- Announcement Bar with Countdown -->
    <div class="gr-announcement-bar">
      <div class="gr-announcement-inner">
        <div class="gr-announcement-text">
          <p class="gr-announcement-title">Summer Sale</p>
          <p class="gr-announcement-sub">Save up to 60% + Free Gifts</p>
        </div>
        <div class="gr-countdown" id="gr-countdown">
          <div class="gr-countdown-unit">
            <span class="gr-countdown-val" id="gr-hrs">03</span>
            <span class="gr-countdown-label">HRS</span>
          </div>
          <span class="gr-countdown-sep">:</span>
          <div class="gr-countdown-unit">
            <span class="gr-countdown-val" id="gr-min">00</span>
            <span class="gr-countdown-label">MIN</span>
          </div>
          <span class="gr-countdown-sep">:</span>
          <div class="gr-countdown-unit">
            <span class="gr-countdown-val" id="gr-sec">00</span>
            <span class="gr-countdown-label">SEC</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Navigation -->
    <nav class="gr-nav">
      <div class="gr-nav-inner">
        <div class="gr-nav-left"></div>
        <a href="/" class="gr-nav-center">
          <img loading="eager" src="{{ 'luna-naturals-logo-cropped.webp' | asset_url }}" alt="Luna Natural" class="gr-nav-logo" />
        </a>
        <div class="gr-nav-right"></div>
      </div>
    </nav>
  </header>

  <!-- ================================================================
       HERO SECTION — Split Layout with Image Carousel
       ================================================================ -->
  <section class="gr-hero">
    <div class="gr-hero-inner">
      <!-- Text Side -->
      <div class="gr-hero-text">
        <div class="gr-hero-text-content">
          <h2 class="gr-hero-heading">
            <span class="gr-hero-rotating-word visible" id="gr-rotating-word">Tick</span>
            Protection You Can Actually Trust.
          </h2>

