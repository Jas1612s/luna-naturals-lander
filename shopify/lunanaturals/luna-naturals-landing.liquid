     ═══════════════════════════════════════════════ -->
<div id="live-order-toast" style="position:fixed;bottom:95px;left:12px;max-width:340px;z-index:40;transition:all 0.4s cubic-bezier(0.16,1,0.3,1);transform:translateY(12px);opacity:0;pointer-events:none">
  <div style="background:#fff;border-radius:16px;box-shadow:0 4px 24px rgba(0,0,0,0.08);border:1px solid rgba(0,0,0,0.04);padding:12px 14px;display:flex;align-items:center;gap:12px">
    <div style="width:40px;height:40px;border-radius:8px;overflow:hidden;background:var(--gr-cream);flex-shrink:0">
      <img src="{{ 'luna-natural-pouch.webp' | asset_url }}" alt="" width="40" height="40" style="width:100%;height:100%;object-fit:cover">
    </div>
    <div style="min-width:0;flex:1">
      <p style="font-size:13px;color:var(--gr-dark);line-height:1.3">
        <span id="toast-name" style="font-weight:600"></span> from <span id="toast-city"></span>
      </p>
      <p style="font-size:12px;color:var(--gr-sage);margin-top:2px;line-height:1.3">
        bought <span id="toast-product"></span> &middot; <span id="toast-time"></span>
      </p>
    </div>
  </div>
</div>

</main>
</body>
</html>

<!-- ═══════════════════════════════════════════════════════════════
     ALL JAVASCRIPT
     ═══════════════════════════════════════════════════════════════ -->
<script>
(function() {
  'use strict';

  /* ─────────────────────────────────────────
     1. TESTIMONIAL CAROUSEL (3D perspective)
     ───────────────────────────────────────── */
  var testimonials = [
    {
      name: "Jeremy H.",
      designation: "Subscriber Since 2025 \u2022 Verified Buyer",
      quote: "I just stick one on my arm before heading outside and forget about it. 8 hours later, zero bites. It\u2019s honestly the simplest thing I\u2019ve ever used."
    },
    {
      name: "Lisa C.",
      designation: "Outdoor Enthusiast \u2022 Verified Buyer",
      quote: "I was spending $40+ a month on sprays that barely worked. One box of these lasts the whole season for less than $15. The quality is incredible."
    },
    {
      name: "Sarah M.",
      designation: "Mom of 2 \u2022 Verified Buyer",
      quote: "My toddler thinks they\u2019re dinosaur stickers and wants to put them on herself every morning. Three weeks, zero bites. The fun designs are such a smart touch!"
    },
    {
      name: "Rebecca D.",
      designation: "Adventure Couple \u2022 Verified Buyer",
      quote: "Took these on a 4-day hiking trip. We used maybe 20 patches total for both of us. Not a single bite the entire trip. Absolute must-have for the outdoors."
    }
  ];

  var tActiveIndex = 0;
  var tLength = testimonials.length;
  var tAutoplayTimer = null;
  var tImages = document.querySelectorAll('.testimonial-img');
  var tNameEl = document.getElementById('testimonial-name');
  var tDesignEl = document.getElementById('testimonial-designation');
  var tQuoteEl = document.getElementById('testimonial-quote');
  var tImagesContainer = document.getElementById('testimonial-images');
  var tPrevBtn = document.getElementById('testimonial-prev');
  var tNextBtn = document.getElementById('testimonial-next');

  function calculateGap(width) {
    var minWidth = 1024, maxWidth = 1456, minGap = 60, maxGap = 86;
    if (width <= minWidth) return minGap;
    if (width >= maxWidth) return Math.max(minGap, maxGap + 0.06018 * (width - maxWidth));
    return minGap + (maxGap - minGap) * ((width - minWidth) / (maxWidth - minWidth));
  }

  function updateTestimonialPositions() {
    if (!tImagesContainer) return;
    var containerWidth = tImagesContainer.offsetWidth;
    var gap = calculateGap(containerWidth);
    var maxStickUp = gap * 0.8;

    tImages.forEach(function(el, index) {
      var isActive = index === tActiveIndex;
      var isLeft = ((tActiveIndex - 1 + tLength) % tLength) === index;
      var isRight = ((tActiveIndex + 1) % tLength) === index;

      if (isActive) {
        el.style.zIndex = '3';
        el.style.opacity = '1';
        el.style.pointerEvents = 'auto';
        el.style.transform = 'translateX(0px) translateY(0px) scale(1) rotateY(0deg)';
      } else if (isLeft) {
        el.style.zIndex = '2';
        el.style.opacity = '1';
        el.style.pointerEvents = 'auto';
        el.style.transform = 'translateX(-' + gap + 'px) translateY(-' + maxStickUp + 'px) scale(0.85) rotateY(15deg)';
      } else if (isRight) {
        el.style.zIndex = '2';
        el.style.opacity = '1';
        el.style.pointerEvents = 'auto';
        el.style.transform = 'translateX(' + gap + 'px) translateY(-' + maxStickUp + 'px) scale(0.85) rotateY(-15deg)';
      } else {
        el.style.zIndex = '1';
        el.style.opacity = '0';
        el.style.pointerEvents = 'none';
      }
    });
  }

  function updateTestimonialText() {
    var t = testimonials[tActiveIndex];
    if (!tNameEl) return;

    // Fade out
    var contentDiv = document.getElementById('testimonial-text');
    if (contentDiv) {
      contentDiv.style.transition = 'opacity 0.2s, transform 0.2s';
      contentDiv.style.opacity = '0';
      contentDiv.style.transform = 'translateY(-10px)';
    }

    setTimeout(function() {
      tNameEl.textContent = t.name;
      tDesignEl.textContent = t.designation;

      // Word-by-word blur-in animation
      var words = t.quote.split(' ');
      tQuoteEl.innerHTML = '';
      words.forEach(function(word, i) {
        var span = document.createElement('span');
        span.textContent = word + '\u00A0';
        span.style.display = 'inline-block';
        span.style.opacity = '0';
        span.style.filter = 'blur(10px)';
        span.style.transform = 'translateY(5px)';
        span.style.transition = 'opacity 0.22s ease ' + (i * 0.025) + 's, filter 0.22s ease ' + (i * 0.025) + 's, transform 0.22s ease ' + (i * 0.025) + 's';
        tQuoteEl.appendChild(span);
      });

      // Fade in
      if (contentDiv) {
        contentDiv.style.opacity = '1';
        contentDiv.style.transform = 'translateY(0)';
      }

      // Trigger word animations
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          var spans = tQuoteEl.querySelectorAll('span');
          spans.forEach(function(s) {
            s.style.opacity = '1';
            s.style.filter = 'blur(0px)';
            s.style.transform = 'translateY(0)';
          });
        });
      });
    }, 200);
  }

  function goToTestimonial(index) {
    tActiveIndex = ((index % tLength) + tLength) % tLength;
    updateTestimonialPositions();
    updateTestimonialText();
  }

  function startTestimonialAutoplay() {
    if (tAutoplayTimer) clearInterval(tAutoplayTimer);
    tAutoplayTimer = setInterval(function() {
      goToTestimonial(tActiveIndex + 1);
    }, 5000);
  }

  if (tPrevBtn) {
    tPrevBtn.addEventListener('click', function() {
      goToTestimonial(tActiveIndex - 1);
      if (tAutoplayTimer) clearInterval(tAutoplayTimer);
    });
    tPrevBtn.addEventListener('mouseenter', function() { this.style.background = 'var(--gr-accent)'; });
    tPrevBtn.addEventListener('mouseleave', function() { this.style.background = 'rgba(255,255,255,0.15)'; });
  }
  if (tNextBtn) {
    tNextBtn.addEventListener('click', function() {
      goToTestimonial(tActiveIndex + 1);
      if (tAutoplayTimer) clearInterval(tAutoplayTimer);
    });
    tNextBtn.addEventListener('mouseenter', function() { this.style.background = 'var(--gr-accent)'; });
    tNextBtn.addEventListener('mouseleave', function() { this.style.background = 'rgba(255,255,255,0.15)'; });
  }

  // Touch swipe for testimonials
  if (tImagesContainer) {
    var tTouchStartX = 0;
    tImagesContainer.addEventListener('touchstart', function(e) {
      tTouchStartX = e.touches[0].clientX;
    }, { passive: true });
    tImagesContainer.addEventListener('touchend', function(e) {
      var diff = tTouchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goToTestimonial(tActiveIndex + 1);
        else goToTestimonial(tActiveIndex - 1);
        if (tAutoplayTimer) clearInterval(tAutoplayTimer);
      }
    }, { passive: true });
  }

  // Keyboard navigation
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft') { goToTestimonial(tActiveIndex - 1); if (tAutoplayTimer) clearInterval(tAutoplayTimer); }
    if (e.key === 'ArrowRight') { goToTestimonial(tActiveIndex + 1); if (tAutoplayTimer) clearInterval(tAutoplayTimer); }
  });

  // Init testimonial carousel
  goToTestimonial(0);
  startTestimonialAutoplay();

  // Responsive grid for testimonials
  function updateTestimonialGrid() {
    var grid = document.getElementById('testimonial-grid');
    var imgContainer = document.getElementById('testimonial-images');
    var arrowContainer = document.getElementById('testimonial-arrows');
    if (!grid) return;
    if (window.innerWidth >= 768) {
      grid.style.gridTemplateColumns = '1fr 1fr';
      grid.style.gap = '3rem';
      if (imgContainer) imgContainer.style.height = '22rem';
      if (arrowContainer) arrowContainer.style.paddingTop = '0';
    } else {
      grid.style.gridTemplateColumns = '1fr';
      grid.style.gap = '2rem';
      if (imgContainer) imgContainer.style.height = '20rem';
      if (arrowContainer) arrowContainer.style.paddingTop = '1.5rem';
    }
    updateTestimonialPositions();
  }
  updateTestimonialGrid();
  window.addEventListener('resize', updateTestimonialGrid);


  /* ─────────────────────────────────────────
     2. UGC VIDEO PLAY/PAUSE
     ───────────────────────────────────────── */
  document.querySelectorAll('.ugc-card').forEach(function(card) {
    card.addEventListener('click', function() {
      var video = card.querySelector('video');
      var playBtn = card.querySelector('.ugc-play-btn');
      if (!video) return;

      if (video.paused) {
        // Lazy-load video src from poster path
        if (!video.src || video.src === window.location.href || video.src === '') {
          // Derive video src from poster: replace poster path pattern
          var poster = video.getAttribute('poster') || '';
          var videoSrc = poster.replace('-poster.webp', '.mp4').replace('-poster.jpg', '.mp4');
          video.src = videoSrc;
        }
        video.play().then(function() {
          if (playBtn) playBtn.style.opacity = '0';
        }).catch(function() {});
      } else {
        video.pause();
        if (playBtn) playBtn.style.opacity = '1';
      }
    });
  });


  /* ─────────────────────────────────────────
     3. FAQ ACCORDION
     ───────────────────────────────────────── */
  var faqOpenIndex = null;
  document.querySelectorAll('.faq-trigger').forEach(function(btn, index) {
    btn.addEventListener('click', function() {
      var allAnswers = document.querySelectorAll('.faq-answer');
      var allIcons = document.querySelectorAll('.faq-icon');

      if (faqOpenIndex === index) {
        // Close current
        allAnswers[index].style.maxHeight = '0';
        allIcons[index].textContent = '+';
        allIcons[index].style.transform = 'rotate(0deg)';
        faqOpenIndex = null;
      } else {
        // Close all
        allAnswers.forEach(function(a, i) {
          a.style.maxHeight = '0';
          allIcons[i].textContent = '+';
          allIcons[i].style.transform = 'rotate(0deg)';
        });
        // Open clicked
        allAnswers[index].style.maxHeight = allAnswers[index].scrollHeight + 'px';
        allIcons[index].textContent = '\u2212';
        allIcons[index].style.transform = 'rotate(180deg)';
        faqOpenIndex = index;
      }
    });
  });


  /* ─────────────────────────────────────────
     4. STICKY MOBILE CTA
     ───────────────────────────────────────── */
  var stickyCta = document.getElementById('sticky-mobile-cta');
  if (stickyCta) {
    // Hide on desktop (>= 1024px)
    function updateStickyVisibility() {
      if (window.innerWidth >= 1024) {
        stickyCta.style.display = 'none';
      } else {
        stickyCta.style.display = '';
      }
    }
    updateStickyVisibility();
    window.addEventListener('resize', updateStickyVisibility);

    window.addEventListener('scroll', function() {
      if (window.innerWidth >= 1024) return;
      if (window.scrollY > 600) {
        stickyCta.style.transform = 'translateY(0)';
      } else {
        stickyCta.style.transform = 'translateY(100%)';
      }
    }, { passive: true });
  }


  /* ─────────────────────────────────────────
     5. LIVE ORDER TOAST
     ───────────────────────────────────────── */
  var toastEl = document.getElementById('live-order-toast');
  var toastNameEl = document.getElementById('toast-name');
  var toastCityEl = document.getElementById('toast-city');
  var toastProductEl = document.getElementById('toast-product');
  var toastTimeEl = document.getElementById('toast-time');

  var toastNames = [
    "Sarah M.", "Emily R.", "Jess K.", "Ashley T.", "Amanda P.", "Mike D.", "David L.", "Chris B.",
    "Jen W.", "Lisa R.", "Rebecca D.", "Michelle H.", "Nicole S.", "Steph C.", "Rachel G.",
    "Dan F.", "Matt J.", "Andrew N.", "James W.", "Rob T.", "Lauren K.", "Megan A.", "Britt V.",
    "Sam Q.", "Christina E.", "Kevin M.", "Brian D.", "Jason R.", "Tyler B.", "Brandon S."
  ];
  var toastCities = [
    "Austin, TX", "Portland, OR", "Nashville, TN", "Denver, CO", "San Diego, CA",
    "Charlotte, NC", "Seattle, WA", "Phoenix, AZ", "Tampa, FL", "Raleigh, NC",
    "Minneapolis, MN", "Atlanta, GA", "Chicago, IL", "Miami, FL", "Dallas, TX",
    "Boston, MA", "Brooklyn, NY", "Sacramento, CA", "Orlando, FL", "Columbus, OH"
  ];
  var toastProducts = ["1-pack", "1-pack", "2-pack", "2-pack", "3-pack", "4-pack"];
  var toastTimes = ["just now", "2 min ago", "5 min ago", "11 min ago", "18 min ago", "24 min ago", "33 min ago", "41 min ago", "57 min ago"];

  function randomItem(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

  function showOrderToast() {
    if (!toastEl) return;
    toastNameEl.textContent = randomItem(toastNames);
    toastCityEl.textContent = randomItem(toastCities);
    toastProductEl.textContent = randomItem(toastProducts);
    toastTimeEl.textContent = randomItem(toastTimes);

    toastEl.style.transform = 'translateY(0)';
    toastEl.style.opacity = '1';
    toastEl.style.pointerEvents = 'auto';

    var displayDuration = 3500 + Math.random() * 2500;
    setTimeout(function() {
      toastEl.style.transform = 'translateY(12px)';
      toastEl.style.opacity = '0';
      toastEl.style.pointerEvents = 'none';
      scheduleNextToast();
    }, displayDuration);
  }

  function scheduleNextToast() {
    var roll = Math.random();
    var delay;
    if (roll < 0.4) {
      delay = 8000 + Math.random() * 7000;    // 8-15s
    } else if (roll < 0.8) {
      delay = 18000 + Math.random() * 17000;  // 18-35s
    } else {
      delay = 40000 + Math.random() * 30000;  // 40-70s
    }
    setTimeout(showOrderToast, delay);
  }

  // First toast after 5-15s
  setTimeout(showOrderToast, 5000 + Math.random() * 10000);

  // Adjust toast position based on sticky CTA
  function updateToastPosition() {
    if (!toastEl) return;
    if (window.innerWidth >= 1024) {
      toastEl.style.bottom = '24px';
      toastEl.style.left = '16px';
    } else {
      toastEl.style.bottom = '95px';
      toastEl.style.left = '12px';
    }
  }
  updateToastPosition();
  window.addEventListener('resize', updateToastPosition);


  /* ─────────────────────────────────────────
     6. SCROLL ANIMATIONS (fade-up on scroll)
     ───────────────────────────────────────── */
  if ('IntersectionObserver' in window) {
    var scrollElements = document.querySelectorAll('[data-scroll-animate]');
    var scrollObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          scrollObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    scrollElements.forEach(function(el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      scrollObserver.observe(el);
    });
  }


  /* ─────────────────────────────────────────
     7. COUNTUP ANIMATION (for stat numbers)
     ───────────────────────────────────────── */
  function animateCountUp(el, target, duration) {
    var start = 0;
    var startTime = null;
    var suffix = el.getAttribute('data-suffix') || '';
    var prefix = el.getAttribute('data-prefix') || '';

    function step(timestamp) {
      if (!startTime) startTime = timestamp;
      var progress = Math.min((timestamp - startTime) / duration, 1);
      // Ease out cubic
      var eased = 1 - Math.pow(1 - progress, 3);
      var current = Math.floor(eased * target);
      el.textContent = prefix + current.toLocaleString() + suffix;
      if (progress < 1) requestAnimationFrame(step);
      else el.textContent = prefix + target.toLocaleString() + suffix;
    }
    requestAnimationFrame(step);
  }

  if ('IntersectionObserver' in window) {
    var countUpElements = document.querySelectorAll('[data-countup]');
    var countUpObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var target = parseInt(entry.target.getAttribute('data-countup'), 10);
          var duration = parseInt(entry.target.getAttribute('data-countup-duration') || '2000', 10);
          animateCountUp(entry.target, target, duration);
          countUpObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    countUpElements.forEach(function(el) { countUpObserver.observe(el); });
  }


  /* ─────────────────────────────────────────
     8. COUNTDOWN TIMER
     ───────────────────────────────────────── */
  var countdownEls = document.querySelectorAll('[data-countdown]');
  if (countdownEls.length > 0) {
    function updateCountdowns() {
      countdownEls.forEach(function(el) {
        var endTime = el.getAttribute('data-countdown');
        if (!endTime) return;
        var now = new Date().getTime();
        var end = new Date(endTime).getTime();
        var diff = end - now;
        if (diff <= 0) {
          el.textContent = '00:00:00';
          return;
        }
        var hrs = Math.floor(diff / 3600000);
        var mins = Math.floor((diff % 3600000) / 60000);
        var secs = Math.floor((diff % 60000) / 1000);
        el.textContent =
          (hrs < 10 ? '0' : '') + hrs + ':' +
          (mins < 10 ? '0' : '') + mins + ':' +
          (secs < 10 ? '0' : '') + secs;
      });
    }
    updateCountdowns();
    setInterval(updateCountdowns, 1000);
  }


  /* ─────────────────────────────────────────
     9. HERO CAROUSEL (if present in Part 1)
     ───────────────────────────────────────── */
  var heroSlides = document.querySelectorAll('[data-hero-slide]');
  var heroDots = document.querySelectorAll('[data-hero-dot]');
  var heroIndex = 0;

  function showHeroSlide(index) {
    heroSlides.forEach(function(slide, i) {
      slide.style.opacity = i === index ? '1' : '0';
      slide.style.zIndex = i === index ? '1' : '0';
    });
    heroDots.forEach(function(dot, i) {
      dot.style.opacity = i === index ? '1' : '0.5';
    });
  }

  if (heroSlides.length > 1) {
    showHeroSlide(0);
    setInterval(function() {
      heroIndex = (heroIndex + 1) % heroSlides.length;
      showHeroSlide(heroIndex);
    }, 4000);

    heroDots.forEach(function(dot, i) {
      dot.addEventListener('click', function() {
        heroIndex = i;
        showHeroSlide(heroIndex);
      });
    });
  }


  /* ─────────────────────────────────────────
     10. REVIEW CAROUSEL (if present in Part 2)
     ───────────────────────────────────────── */
  var reviewTrack = document.getElementById('review-carousel-track');
  var reviewPrev = document.getElementById('review-prev');
  var reviewNext = document.getElementById('review-next');

  if (reviewTrack) {
    var reviewScrollAmount = 320;

    if (reviewPrev) {
      reviewPrev.addEventListener('click', function() {
        reviewTrack.scrollBy({ left: -reviewScrollAmount, behavior: 'smooth' });
      });
    }
    if (reviewNext) {
      reviewNext.addEventListener('click', function() {
        reviewTrack.scrollBy({ left: reviewScrollAmount, behavior: 'smooth' });
      });
    }
  }


  /* ─────────────────────────────────────────
     11. BUNDLE SELECTOR (if present in Part 2)
     ───────────────────────────────────────── */
  var bundleCards = document.querySelectorAll('[data-bundle-card]');
  bundleCards.forEach(function(card) {
    card.addEventListener('click', function() {
      bundleCards.forEach(function(c) {
        c.style.borderColor = 'rgba(0,0,0,0.05)';
        c.style.boxShadow = 'none';
        var radio = c.querySelector('[data-bundle-radio]');
        if (radio) { radio.style.background = 'transparent'; radio.innerHTML = ''; }
      });

      card.style.borderColor = 'var(--gr-accent)';
      card.style.boxShadow = '0 0 0 2px var(--gr-accent)';
      var radio = card.querySelector('[data-bundle-radio]');
      if (radio) {
        radio.style.background = 'var(--gr-accent)';
        radio.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>';
      }

      // Update buy box price if data attributes exist
      var price = card.getAttribute('data-price');
      var comparePrice = card.getAttribute('data-compare-price');
      var priceEl = document.getElementById('buybox-price');
      var comparePriceEl = document.getElementById('buybox-compare-price');
      if (priceEl && price) priceEl.textContent = price;
      if (comparePriceEl && comparePrice) comparePriceEl.textContent = comparePrice;
    });
  });


  /* ─────────────────────────────────────────
     12. FOOTER GRID RESPONSIVE
     ───────────────────────────────────────── */
  function updateFooterGrid() {
    var footerGrid = document.getElementById('footer-grid');
    if (!footerGrid) return;
    if (window.innerWidth >= 1024) {
      footerGrid.style.gridTemplateColumns = 'repeat(4, 1fr)';
      footerGrid.style.gap = '48px';
    } else if (window.innerWidth >= 768) {
      footerGrid.style.gridTemplateColumns = 'repeat(2, 1fr)';
      footerGrid.style.gap = '48px';
    } else {
      footerGrid.style.gridTemplateColumns = '1fr';
      footerGrid.style.gap = '32px';
    }
  }
  updateFooterGrid();
  window.addEventListener('resize', updateFooterGrid);


  /* ─────────────────────────────────────────
     13. UGC RESPONSIVE WIDTHS
     ───────────────────────────────────────── */
  function updateUgcWidths() {
    var cards = document.querySelectorAll('.ugc-card');
    var w = window.innerWidth;
    cards.forEach(function(card) {
      if (w >= 1024) card.style.width = '200px';
      else if (w >= 768) card.style.width = '220px';
      else card.style.width = '200px';
    });
  }
  updateUgcWidths();
  window.addEventListener('resize', updateUgcWidths);

})();
</script>

<style>
  /* Scrollbar hide utility */
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }

  /* Responsive testimonial grid handled via JS, but add this media query for
     initial render before JS runs */
  @media (min-width: 768px) {
    #testimonial-grid { grid-template-columns: 1fr 1fr !important; gap: 3rem !important; }
    #testimonial-images { height: 22rem !important; }
    #testimonial-arrows { padding-top: 0 !important; }
  }

  /* Responsive UGC card widths */
  @media (min-width: 768px) and (max-width: 1023px) {
    .ugc-card { width: 220px !important; }
  }

  /* Hide sticky CTA on large screens */
  @media (min-width: 1024px) {
    #sticky-mobile-cta { display: none !important; }
    #live-order-toast { bottom: 24px !important; left: 16px !important; }
  }

