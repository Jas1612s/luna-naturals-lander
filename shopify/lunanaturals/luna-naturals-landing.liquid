<!-- ═══════════════════════════════════════════════
     PART 2A — JavaScript
     ═══════════════════════════════════════════════ -->
<script>
(function() {
  /* ── Review Carousel ── */
  var reviewActive = 0;
  var reviewTotal = 6;
  var reviewScroll = document.getElementById('review-scroll');

  function reviewUpdateCards() {
    for (var i = 0; i < reviewTotal; i++) {
      var card = document.getElementById('review-card-' + i);
      var dot = document.getElementById('review-dot-' + i);
      var quote = card.querySelector('.review-quote');
      var tag = card.querySelector('.review-tag');
      if (i === reviewActive) {
        card.style.background = '#4A5A2E';
        card.style.borderColor = '#4A5A2E';
        card.style.transform = 'scale(1.02)';
        card.style.boxShadow = '0 10px 15px -3px rgba(0,0,0,0.3)';
        if (quote) quote.style.color = 'rgba(255,255,255,0.9)';
        if (tag) tag.style.color = 'rgba(255,255,255,0.6)';
        if (dot) { dot.style.width = '24px'; dot.style.opacity = '1'; }
      } else {
        card.style.background = 'rgba(255,255,255,0.1)';
        card.style.borderColor = 'rgba(255,255,255,0.15)';
        card.style.transform = 'scale(1)';
        card.style.boxShadow = 'none';
        if (quote) quote.style.color = 'rgba(255,255,255,0.7)';
        if (tag) tag.style.color = 'rgba(255,255,255,0.4)';
        if (dot) { dot.style.width = '8px'; dot.style.opacity = '0.3'; }
      }
    }
  }

  window.reviewScrollTo = function(index) {
    reviewActive = index;
    var container = reviewScroll;
    if (!container) return;
    var card = container.children[index];
    if (card) {
      container.scrollTo({
        left: card.offsetLeft - container.offsetLeft - 16,
        behavior: 'smooth'
      });
    }
    reviewUpdateCards();
  };

  window.reviewPrev = function() {
    window.reviewScrollTo(reviewActive === 0 ? reviewTotal - 1 : reviewActive - 1);
  };

  window.reviewNext = function() {
    window.reviewScrollTo(reviewActive === reviewTotal - 1 ? 0 : reviewActive + 1);
  };

  /* Sync active on manual scroll */
  if (reviewScroll) {
    reviewScroll.addEventListener('scroll', function() {
      var scrollLeft = reviewScroll.scrollLeft;
      var firstCard = reviewScroll.children[0];
      var cardWidth = firstCard ? firstCard.offsetWidth : 300;
      var newIndex = Math.round(scrollLeft / (cardWidth + 20));
      if (newIndex !== reviewActive && newIndex >= 0 && newIndex < reviewTotal) {
        reviewActive = newIndex;
        reviewUpdateCards();
      }
    });
  }

  /* Initialize first card as active */
  reviewUpdateCards();

  /* ── CountUp animation ── */
  var countUpEl = document.getElementById('review-countup');
  if (countUpEl) {
    var countUpDone = false;
    var countObserver = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting && !countUpDone) {
        countUpDone = true;
        var target = 50000;
        var duration = 2000;
        var start = performance.now();
        function step(now) {
          var progress = Math.min((now - start) / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          countUpEl.textContent = Math.floor(eased * target).toLocaleString();
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
        countObserver.disconnect();
      }
    }, { threshold: 0.5 });
    countObserver.observe(countUpEl);
  }

  /* ── Responsive: review arrows + dots + card widths ── */
  function reviewResponsive() {
    var w = window.innerWidth;
    var arrowsDesktop = document.getElementById('review-arrows-desktop');
    var dots = document.getElementById('review-dots');

    /* Show desktop arrows at md (768px+) */
    if (arrowsDesktop) {
      arrowsDesktop.style.display = w >= 768 ? 'flex' : 'none';
    }
    /* Hide dots on md+ */
    if (dots) {
      dots.style.display = w >= 768 ? 'none' : 'flex';
    }
    /* Card widths: 300 on mobile, 360 on md+ */
    for (var i = 0; i < reviewTotal; i++) {
      var card = document.getElementById('review-card-' + i);
      if (card) card.style.width = w >= 768 ? '360px' : '300px';
    }

    /* Responsive padding for carousel section */
    var section = document.getElementById('review-carousel');
    if (section) {
      if (w >= 1024) section.style.padding = '112px 16px';
      else if (w >= 768) section.style.padding = '80px 16px';
      else section.style.padding = '56px 16px';
    }
  }

  /* ── Responsive: ValueProps mobile/desktop toggle ── */
  function vpResponsive() {
    var w = window.innerWidth;
    var mobile = document.getElementById('vp-mobile');
    var desktop = document.getElementById('vp-desktop');
    if (w >= 1024) {
      if (mobile) mobile.style.display = 'none';
      if (desktop) desktop.style.display = 'grid';
    } else {
      if (mobile) mobile.style.display = 'block';
      if (desktop) desktop.style.display = 'none';
    }

    /* Responsive padding */
    var vpSection = document.getElementById('value-props');
    if (vpSection) {
      vpSection.style.padding = w >= 768 ? '96px 16px' : '64px 16px';
    }

    /* Responsive heading margin */
    var vpHeading = vpSection ? vpSection.querySelector('div[style*="text-align:center"]') : null;
    if (vpHeading) {
      vpHeading.style.marginBottom = w >= 768 ? '64px' : '48px';
    }

    /* Desktop pouch width */
    var desktopPouch = desktop ? desktop.querySelector('a div') : null;
    if (desktopPouch && w >= 1280) {
      desktopPouch.style.width = '460px';
    } else if (desktopPouch) {
      desktopPouch.style.width = '400px';
    }
  }

  /* ── Responsive: FindYourFlavor grid layout ── */
  function fyfResponsive() {
    var w = window.innerWidth;
    var grid = document.getElementById('fyf-grid');
    var section = document.getElementById('find-your-flavor');
    if (grid) {
      if (w >= 1024) {
        grid.style.display = 'grid';
        grid.style.gridTemplateColumns = '1fr 1.2fr';
        grid.style.gap = '64px';
        grid.style.alignItems = 'center';
        /* Remove top margin on badge grid for desktop alignment */
        var badgeGrid = grid.querySelectorAll('div[style*="grid-template-columns:1fr 1fr"]');
        if (badgeGrid.length) badgeGrid[0].style.marginTop = '0';
      } else {
        grid.style.display = 'block';
        grid.style.gridTemplateColumns = '';
        grid.style.gap = '';
        grid.style.alignItems = '';
        var badgeGrid2 = grid.querySelectorAll('div[style*="grid-template-columns:1fr 1fr"]');
        if (badgeGrid2.length) badgeGrid2[0].style.marginTop = '40px';
      }
    }
    /* Responsive padding + max-width */
    if (section) {
      if (w >= 1024) {
        section.style.padding = '112px 24px';
      } else if (w >= 768) {
        section.style.padding = '96px 24px';
      } else {
        section.style.padding = '64px 16px';
      }
    }
  }

  /* ── BenefitsScroll: IntersectionObserver fade-in ── */
  var benefitsLines = document.querySelectorAll('.benefits-scroll-line');
  if (benefitsLines.length) {
    var benefitsObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          entry.target.style.filter = 'blur(0px)';
          benefitsObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    benefitsLines.forEach(function(line) {
      benefitsObserver.observe(line);
    });
  }

  /* ── BenefitsScroll: responsive font + gaps ── */
  function benefitsResponsive() {
    var w = window.innerWidth;
    var container = document.querySelector('#benefits-scroll > div');
    if (!container) return;
    if (w >= 1024) {
      container.style.padding = '144px 16px 80px';
      container.style.gap = '112px';
      benefitsLines.forEach(function(l) { l.style.fontSize = '120px'; });
    } else if (w >= 768) {
      container.style.padding = '144px 16px 80px';
      container.style.gap = '80px';
      benefitsLines.forEach(function(l) { l.style.fontSize = '96px'; });
    } else {
      container.style.padding = '96px 16px 80px';
      container.style.gap = '56px';
      benefitsLines.forEach(function(l) { l.style.fontSize = 'clamp(2.5rem,13vw,4.5rem)'; });
    }
  }

  /* ── Run all responsive checks ── */
  function handleResize() {
    reviewResponsive();
    vpResponsive();
    fyfResponsive();
    benefitsResponsive();
  }

  handleResize();
  window.addEventListener('resize', handleResize);

  /* ── Hover effects for review arrow buttons ── */
  var arrowBtns = document.querySelectorAll('#review-arrows-desktop button');
  arrowBtns.forEach(function(btn) {
    btn.addEventListener('mouseenter', function() { btn.style.background = 'rgba(255,255,255,0.1)'; });
    btn.addEventListener('mouseleave', function() { btn.style.background = 'transparent'; });
  });

  /* ── Hover effects for review cards ── */
  for (var ci = 0; ci < reviewTotal; ci++) {
    (function(idx) {
      var card = document.getElementById('review-card-' + idx);
      if (!card) return;
      card.addEventListener('mouseenter', function() {
        if (idx !== reviewActive) {
          card.style.borderColor = 'rgba(255,255,255,0.3)';
          card.style.background = 'rgba(255,255,255,0.15)';
        }
      });
      card.addEventListener('mouseleave', function() {
        if (idx !== reviewActive) {
          card.style.borderColor = 'rgba(255,255,255,0.15)';
          card.style.background = 'rgba(255,255,255,0.1)';
        }
      });
    })(ci);
  }

})();
</script>
