    { packs: 1, patches: 48,  priceEach: 16.15, compareEach: 24.99, tag: null,         image: "{{ 'bundle-1pack.webp' | asset_url }}" },
    { packs: 2, patches: 96,  priceEach: 11.48, compareEach: 24.99, tag: null,         image: "{{ 'bundle-2pack.webp' | asset_url }}" },
    { packs: 3, patches: 144, priceEach: 10.20, compareEach: 24.99, tag: "Bestseller", image: "{{ 'bundle-3pack.webp' | asset_url }}" },
    { packs: 4, patches: 192, priceEach:  8.93, compareEach: 24.99, tag: null,         image: "{{ 'bundle-4pack.webp' | asset_url }}" }
  ];

  /* ---------- state ---------- */
  var activeImage = 0;
  var bundleSize = 3;
  var offerType = 'subscribe';
  var subDiscount = 0.15;
  var patchCount = 90;
  var touchStartX = 0;

  /* ---------- helpers ---------- */
  function $(id) { return document.getElementById(id); }
  function fix(n) { return Number(n.toFixed(2)); }

  /* ---------- build gallery ---------- */
  function buildGallery() {
    var strip = $('bb-img-strip');
    strip.innerHTML = '';
    strip.style.width = (gallery.length * 100) + '%';
    for (var i = 0; i < gallery.length; i++) {
      var div = document.createElement('div');
      div.style.cssText = 'position:relative;height:100%;display:flex;align-items:center;justify-content:center;width:' + (100 / gallery.length) + '%;';
      var img = document.createElement('img');
      img.src = gallery[i];
      img.alt = 'Product image ' + (i + 1);
      img.loading = i === 0 ? 'eager' : 'lazy';
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
      div.appendChild(img);
      strip.appendChild(div);
    }
    updateGalleryPosition();
    buildDots();
    buildThumbs();
  }

  function updateGalleryPosition() {
    var strip = $('bb-img-strip');
    strip.style.transform = 'translateX(-' + (activeImage * (100 / gallery.length)) + '%)';
    updateOverlays();
    updateDots();
    updateThumbs();
  }

  function updateOverlays() {
    var first = $('bb-overlays-first');
    var pack3 = $('bb-overlay-3pack');
    var ba = $('bb-overlay-ba');
    first.style.display = activeImage === 0 ? 'block' : 'none';
    var src = gallery[activeImage] || '';
    pack3.style.display = src.indexOf('3pack') !== -1 ? 'block' : 'none';
    ba.style.display = src.indexOf('before-after') !== -1 ? 'block' : 'none';
  }

  /* ---------- dots ---------- */
  function buildDots() {
    var container = $('bb-dots');
    container.innerHTML = '';
    for (var i = 0; i < gallery.length; i++) {
      var dot = document.createElement('button');
      dot.setAttribute('aria-label', 'View image ' + (i + 1));
      dot.style.cssText = 'border:none;padding:0;cursor:pointer;border-radius:9999px;transition:all 0.2s;';
      dot.dataset.idx = i;
      dot.onclick = function() { activeImage = parseInt(this.dataset.idx); updateGalleryPosition(); };
      container.appendChild(dot);
    }
    updateDots();
  }

  function updateDots() {
    var dots = $('bb-dots').children;
    for (var i = 0; i < dots.length; i++) {
      if (i === activeImage) {
        dots[i].style.width = '24px'; dots[i].style.height = '8px'; dots[i].style.background = '#1C1B10';
      } else {
        dots[i].style.width = '8px'; dots[i].style.height = '8px'; dots[i].style.background = 'rgba(28,27,16,0.3)';
      }
    }
  }

  /* ---------- thumbnails ---------- */
  function buildThumbs() {
    var container = $('bb-thumbs');
    container.innerHTML = '';
    for (var i = 0; i < gallery.length; i++) {
      var btn = document.createElement('button');
      btn.style.cssText = 'width:64px;height:64px;border-radius:12px;overflow:hidden;border:2px solid transparent;transition:border-color 0.2s;cursor:pointer;flex-shrink:0;padding:0;background:none;';
      btn.dataset.idx = i;
      btn.onclick = function() { activeImage = parseInt(this.dataset.idx); updateGalleryPosition(); };
      var img = document.createElement('img');
      img.src = gallery[i];
      img.alt = 'Thumbnail ' + (i + 1);
      img.loading = 'lazy';
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
      btn.appendChild(img);
      container.appendChild(btn);
    }
    updateThumbs();
  }

  function updateThumbs() {
    var btns = $('bb-thumbs').children;
    for (var i = 0; i < btns.length; i++) {
      btns[i].style.borderColor = i === activeImage ? '#4A5A2E' : 'transparent';
    }
  }

  /* ---------- gallery nav ---------- */
  window.bbPrevImg = function() {
    activeImage = (activeImage - 1 + gallery.length) % gallery.length;
    updateGalleryPosition();
  };
  window.bbNextImg = function() {
    activeImage = (activeImage + 1) % gallery.length;
    updateGalleryPosition();
  };

  /* ---------- touch swipe ---------- */
  var galleryEl = $('bb-gallery');
  galleryEl.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, { passive: true });
  galleryEl.addEventListener('touchend', function(e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) { window.bbNextImg(); } else { window.bbPrevImg(); }
    }
  });

  /* ---------- info tabs ---------- */
  window.bbSwitchInfoTab = function(key) {
    var tabs = ['why', 'inside', 'steps', 'reviews'];
    for (var i = 0; i < tabs.length; i++) {
      var el = $('bb-tab-' + tabs[i]);
      if (el) el.style.display = tabs[i] === key ? 'block' : 'none';
    }
    var btns = document.querySelectorAll('.bb-tab-btn');
    for (var j = 0; j < btns.length; j++) {
      if (btns[j].dataset.tab === key) {
        btns[j].style.background = '#fff';
        btns[j].style.color = '#1C1B10';
        btns[j].style.boxShadow = '0 1px 2px rgba(0,0,0,0.05)';
      } else {
        btns[j].style.background = 'transparent';
        btns[j].style.color = '#8B9B7A';
        btns[j].style.boxShadow = 'none';
      }
    }
  };

  /* ---------- bundles UI ---------- */
  function buildBundles() {
    var container = $('bb-bundles');
    container.innerHTML = '';
    for (var i = 0; i < bundles.length; i++) {
      var b = bundles[i];
      var btn = document.createElement('button');
      btn.className = 'bb-bundle-btn';
      btn.dataset.packs = b.packs;
      btn.onclick = function() { bundleSize = parseInt(this.dataset.packs); updateBundles(); recalc(); };
      var totalP = fix(b.priceEach * b.packs);
      var totalC = fix(b.compareEach * b.packs);
      var inner = '';
      if (b.tag) {
        inner += '<span style="position:absolute;top:-10px;left:12px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;background:#1C1B10;color:#fff;padding:2px 10px;border-radius:9999px;">' + b.tag + '</span>';
      }
      inner += '<div style="display:flex;align-items:center;gap:10px;">';
      inner += '<div style="width:40px;height:40px;border-radius:8px;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center;"><img loading="lazy" src="' + b.image + '" alt="' + b.packs + ' pack" style="width:100%;height:100%;object-fit:contain;"></div>';
      inner += '<div>';
      inner += '<p style="font-size:14px;font-weight:700;color:#1C1B10;line-height:1.3;margin:0;">' + b.packs + ' pack' + (b.packs > 1 ? 's' : '') + '</p>';
      inner += '<p style="font-size:18px;font-weight:900;color:#1C1B10;line-height:1.2;margin:2px 0 0;">$' + totalP.toFixed(2) + ' <span style="font-size:12px;font-weight:400;color:#8B9B7A;text-decoration:line-through;">$' + totalC.toFixed(2) + '</span></p>';
      inner += '</div></div>';
      btn.innerHTML = inner;
      container.appendChild(btn);
    }
    updateBundles();
  }

  function updateBundles() {
    var btns = $('bb-bundles').querySelectorAll('.bb-bundle-btn');
    for (var i = 0; i < btns.length; i++) {
      var isActive = parseInt(btns[i].dataset.packs) === bundleSize;
      btns[i].style.cssText = 'position:relative;border-radius:12px;padding:14px;text-align:left;transition:all 0.2s;cursor:pointer;border:2px solid ' +
        (isActive ? '#D4A020' : '#e5e7eb') + ';background:' +
        (isActive ? 'rgba(212,160,32,0.1)' : '#fff') + ';box-shadow:' +
        (isActive ? '0 4px 6px rgba(0,0,0,0.1)' : 'none') + ';outline:none;';
    }
    updateMystery();
  }

  /* ---------- mystery prize ---------- */
  function updateMystery() {
    var unlocked = bundleSize >= 3;
    var outer = $('bb-mystery');
    var inner = $('bb-mystery-inner');
    var lock = $('bb-mystery-lock');
    var emoji = $('bb-mystery-emoji');
    var text = $('bb-mystery-text');
    var sub = $('bb-mystery-sub');

    if (unlocked) {
      outer.style.boxShadow = '0 0 20px rgba(212,160,32,0.3)';
      outer.style.outline = '2px solid #D4A020';
      inner.style.background = 'linear-gradient(to right,rgba(212,160,32,0.2),rgba(212,160,32,0.1))';
      inner.style.border = '1px solid rgba(212,160,32,0.3)';
      lock.style.display = 'none';
      emoji.style.filter = 'none';
      emoji.style.opacity = '1';
      text.style.filter = 'none';
      text.style.opacity = '1';
      sub.innerHTML = '&#127882; You\'re entered to win!';
    } else {
      outer.style.boxShadow = 'none';
      outer.style.outline = 'none';
      inner.style.background = 'rgba(255,255,255,0.05)';
      inner.style.border = '1px solid rgba(255,255,255,0.1)';
      lock.style.display = 'flex';
      emoji.style.filter = 'blur(3px)';
      emoji.style.opacity = '0.6';
      text.style.filter = 'blur(3px)';
      text.style.opacity = '0.6';
      sub.textContent = 'Every 3+ pack order enters to win';
    }
  }

  /* ---------- plan toggle ---------- */
  window.bbSetPlan = function(type) {
    offerType = type;
    updatePlanUI();
    recalc();
  };

  function updatePlanUI() {
    var subBtn = $('bb-plan-sub');
    var onceBtn = $('bb-plan-once');
    var extra = $('bb-plan-sub-extra');
    var benefits = $('bb-sub-benefits');

    if (offerType === 'subscribe') {
      subBtn.style.background = '#D4A020';
      subBtn.style.borderColor = '#D4A020';
      subBtn.style.boxShadow = '0 4px 6px rgba(0,0,0,0.1)';
      extra.style.display = 'block';
      onceBtn.style.background = '#fff';
      onceBtn.style.borderColor = '#e5e7eb';
      onceBtn.style.boxShadow = 'none';
      onceBtn.style.outline = 'none';
      benefits.style.display = 'block';
    } else {
      subBtn.style.background = '#fff';
      subBtn.style.borderColor = '#e5e7eb';
      subBtn.style.boxShadow = 'none';
      extra.style.display = 'none';
      onceBtn.style.background = '#fff';
      onceBtn.style.borderColor = '#4A5A2E';
      onceBtn.style.boxShadow = '0 4px 6px rgba(0,0,0,0.1)';
      onceBtn.style.outline = '2px solid #4A5A2E';
      benefits.style.display = 'none';
    }
  }

  /* ---------- pricing recalc ---------- */
  function recalc() {
    var bd = null;
    for (var i = 0; i < bundles.length; i++) { if (bundles[i].packs === bundleSize) bd = bundles[i]; }
    if (!bd) bd = bundles[2];

    var onetimePrice = fix(bd.priceEach * bd.packs);
    var onetimeCompare = fix(bd.compareEach * bd.packs);
    var subPrice = fix(onetimePrice * (1 - subDiscount));
    var subCompare = onetimePrice;

    var basePrice = offerType === 'subscribe' ? subPrice : onetimePrice;
    var baseCompare = offerType === 'subscribe' ? subCompare : onetimeCompare;
    var currentPrice = fix(basePrice);
    var currentCompare = fix(baseCompare);
    var discount = Math.round(((onetimeCompare - basePrice) / onetimeCompare) * 100);
    var totalPatches = bd.patches;
    var perPatch = fix(basePrice / totalPatches);

    /* update DOM */
    $('bb-compare-price').textContent = '$' + currentCompare.toFixed(2);
    $('bb-current-price').textContent = '$' + currentPrice.toFixed(2);
    $('bb-per-patch').innerHTML = '$' + perPatch.toFixed(2) + '/patch &middot; ' + patchCount + ' patches per pack';

    /* plan prices */
    $('bb-plan-sub-price').innerHTML = '$' + subPrice.toFixed(2) + ' <span style="font-size:12px;text-decoration:line-through;font-weight:400;opacity:0.6;">$' + subCompare.toFixed(2) + '</span>';
    $('bb-plan-once-price').textContent = '$' + onetimePrice.toFixed(2);

    /* CTA */
    $('bb-cta-main').innerHTML = 'Claim deal &middot; Save ' + discount + '%';
    $('bb-cta-sub').innerHTML = 'Total <strong>$' + currentPrice.toFixed(2) + '</strong> <span style="text-decoration:line-through;opacity:0.6;">$' + currentCompare.toFixed(2) + '</span> &middot; $' + perPatch.toFixed(2) + '/patch';

    /* free shipping */
    var freeShipThreshold = 30;
    var remaining = Math.max(0, freeShipThreshold - currentPrice);
    var pct = Math.min(100, Math.round((currentPrice / freeShipThreshold) * 100));
    var qualified = remaining <= 0;

    if (qualified) {
      $('bb-freeship-msg').innerHTML = '<span style="font-weight:700;color:#4A5A2E;">You qualify for free shipping!</span>';
      $('bb-freeship-bar').style.background = '#4A5A2E';
    } else {
      $('bb-freeship-msg').innerHTML = 'You\'re <span style="font-weight:700;color:#D4A020;">$' + remaining.toFixed(2) + '</span> from free shipping';
      $('bb-freeship-bar').style.background = '#D4A020';
    }
    $('bb-freeship-pct').textContent = pct + '%';
    $('bb-freeship-bar').style.width = pct + '%';
  }

  /* ---------- countdown timer ---------- */
  var hrs = 3, min = 0, sec = 0;
  function pad(n) { return String(n).padStart(2, '0'); }
  function tickCountdown() {
    sec--;
    if (sec < 0) { sec = 59; min--; }
    if (min < 0) { min = 59; hrs--; }
    if (hrs < 0) { hrs = 0; min = 0; sec = 0; }
    $('bb-countdown').textContent = pad(hrs) + 'h ' + pad(min) + 'm ' + pad(sec) + 's';
  }
  setInterval(tickCountdown, 1000);

  /* ---------- responsive: single column on mobile ---------- */
  function handleResize() {
    var grid = $('bb-grid');
    if (window.innerWidth < 768) {
      grid.style.gridTemplateColumns = '1fr';
      grid.style.gap = '32px';
    } else {
      grid.style.gridTemplateColumns = '1.1fr 0.9fr';
      grid.style.gap = '48px';
    }
  }
  window.addEventListener('resize', handleResize);

  /* ---------- CTA hover/active ---------- */
  var cta = $('bb-cta');
  cta.addEventListener('mouseenter', function() { this.style.filter = 'brightness(1.1)'; });
  cta.addEventListener('mouseleave', function() { this.style.filter = 'none'; });
  cta.addEventListener('mousedown', function() { this.style.transform = 'scale(0.98)'; });
  cta.addEventListener('mouseup', function() { this.style.transform = 'none'; });

  /* ---------- init ---------- */
  buildGallery();
  buildBundles();
  updatePlanUI();
  recalc();
  handleResize();
})();
</script>
