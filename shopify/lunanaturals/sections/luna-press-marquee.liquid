{% comment %}
  Luna Press Marquee — Scrolling press logos
{% endcomment %}

<style>
  .luna-marquee {
    position: relative;
    overflow: hidden;
    background-color: var(--gr-cream-light, #FAF7F2);
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .luna-marquee__label {
    text-align: center;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gr-sage, #7A8066);
    margin-bottom: 0.75rem;
  }

  .luna-marquee__fade-left,
  .luna-marquee__fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 4rem;
    z-index: 10;
    pointer-events: none;
  }

  .luna-marquee__fade-left {
    left: 0;
    background: linear-gradient(to right, var(--gr-cream-light, #FAF7F2), transparent);
  }

  .luna-marquee__fade-right {
    right: 0;
    background: linear-gradient(to left, var(--gr-cream-light, #FAF7F2), transparent);
  }

  .luna-marquee__track {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    animation: luna-marquee-scroll 30s linear infinite;
    width: max-content;
  }

  .luna-marquee__logo {
    height: 28px;
    width: auto;
    flex-shrink: 0;
    opacity: 0.7;
    filter: grayscale(100%) brightness(0);
  }

  @keyframes luna-marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (min-width: 768px) {
    .luna-marquee__track {
      gap: 3.5rem;
    }
  }
</style>

<section class="luna-marquee">
  <p class="luna-marquee__label">As Seen In</p>

  <div class="luna-marquee__fade-left"></div>

  <div class="luna-marquee__track" data-luna-marquee>
    <img class="luna-marquee__logo" src="{{ 'logo-forbes-black.svg' | asset_url }}" alt="Forbes" loading="lazy">
    <img class="luna-marquee__logo" src="{{ 'logo-nbc.svg' | asset_url }}" alt="NBC" loading="lazy">
    <img class="luna-marquee__logo" src="{{ 'logo-GQ-black.svg' | asset_url }}" alt="GQ" loading="lazy">
    <img class="luna-marquee__logo" src="{{ 'logo-today-black.svg' | asset_url }}" alt="Today" loading="lazy">
    <img class="luna-marquee__logo" src="{{ 'logo-people-black.svg' | asset_url }}" alt="People" loading="lazy">
    {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
    <img class="luna-marquee__logo" src="{{ 'logo-forbes-black.svg' | asset_url }}" alt="Forbes" aria-hidden="true" loading="lazy">
    <img class="luna-marquee__logo" src="{{ 'logo-nbc.svg' | asset_url }}" alt="NBC" aria-hidden="true" loading="lazy">
    <img class="luna-marquee__logo" src="{{ 'logo-GQ-black.svg' | asset_url }}" alt="GQ" aria-hidden="true" loading="lazy">
    <img class="luna-marquee__logo" src="{{ 'logo-today-black.svg' | asset_url }}" alt="Today" aria-hidden="true" loading="lazy">
    <img class="luna-marquee__logo" src="{{ 'logo-people-black.svg' | asset_url }}" alt="People" aria-hidden="true" loading="lazy">
  </div>

  <div class="luna-marquee__fade-right"></div>
</section>

{% schema %}
{
  "name": "Luna Press Marquee",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label text",
      "default": "As Seen In"
    }
  ]
}
{% endschema %}
