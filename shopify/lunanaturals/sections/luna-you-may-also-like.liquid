{% comment %}
  Luna Naturals — You May Also Like
  Cross-sell grid showing Kids patches product (from Adults PDP)
{% endcomment %}

<style>
  .luna-ymal {
    background: var(--gr-green-dark, #1b3a26);
    padding: 56px 16px;
  }
  @media (min-width: 768px) {
    .luna-ymal { padding: 80px 24px; }
  }

  .luna-ymal__container {
    max-width: 480px;
    margin: 0 auto;
  }

  /* Heading */
  .luna-ymal__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .luna-ymal__badge {
    display: inline-block;
    background: var(--gr-accent, #c0392b);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 16px;
    border-radius: 9999px;
    margin-bottom: 16px;
  }

  .luna-ymal__title {
    font-size: 24px;
    color: #fff;
    line-height: 1.2;
  }
  @media (min-width: 768px) {
    .luna-ymal__title { font-size: 30px; }
  }

  .luna-ymal__subtitle {
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    margin-top: 8px;
  }

  /* Product card */
  .luna-ymal__card {
    display: block;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }
  .luna-ymal__card:hover .luna-ymal__card-cta {
    filter: brightness(1.1);
  }

  /* Card top: video / image area */
  .luna-ymal__card-media {
    position: relative;
    background: linear-gradient(135deg, var(--gr-green, #3a7d44), var(--gr-green-dark, #1b3a26));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .luna-ymal__card-media video {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }
  .luna-ymal__card-media img {
    width: 200px;
    height: 200px;
    object-fit: contain;
    transition: transform 0.3s;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.25));
  }
  .luna-ymal__card:hover .luna-ymal__card-media img {
    transform: scale(1.05);
  }
  .luna-ymal__card-media--padded {
    padding: 32px;
  }

  /* Card bottom: details */
  .luna-ymal__card-details {
    background: #fff;
    padding: 24px;
    text-align: center;
  }

  .luna-ymal__card-brand {
    font-size: 10px;
    font-weight: 700;
    color: var(--gr-accent, #c0392b);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .luna-ymal__card-name {
    font-weight: 700;
    font-size: 20px;
    color: var(--gr-dark, #1a1a1a);
    margin-bottom: 4px;
  }

  .luna-ymal__card-tagline {
    font-size: 14px;
    color: var(--gr-sage, #6b7c6b);
    margin-bottom: 16px;
  }

  /* Price row */
  .luna-ymal__price-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 4px;
  }
  .luna-ymal__price {
    font-size: 24px;
    font-weight: 700;
    color: var(--gr-dark, #1a1a1a);
  }
  .luna-ymal__compare-price {
    font-size: 16px;
    color: var(--gr-sage, #6b7c6b);
    text-decoration: line-through;
  }
  .luna-ymal__discount-badge {
    background: rgba(192,57,43,0.1);
    color: var(--gr-accent, #c0392b);
    font-size: 12px;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 9999px;
  }

  .luna-ymal__card-meta {
    font-size: 12px;
    color: var(--gr-sage, #6b7c6b);
    margin-bottom: 20px;
  }

  /* CTA button */
  .luna-ymal__card-cta {
    display: block;
    width: 100%;
    padding: 14px;
    background: var(--gr-accent, #c0392b);
    color: #fff;
    font-weight: 700;
    font-size: 16px;
    border-radius: 9999px;
    text-align: center;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: filter 0.2s;
  }
  .luna-ymal__card-cta:hover { filter: brightness(1.1); }

  .luna-ymal__card-guarantee {
    font-size: 11px;
    color: var(--gr-sage, #6b7c6b);
    margin-top: 12px;
  }
</style>

<section class="luna-ymal">
  <div class="luna-ymal__container">
    <!-- Heading -->
    <div class="luna-ymal__header">
      <div class="luna-ymal__badge">One-Time Offer &mdash; Save $15.00</div>
      <h2 class="luna-ymal__title gr-display">Complete Your Protection</h2>
      <p class="luna-ymal__subtitle">Add Kids Patches and protect the whole family.</p>
    </div>

    <!-- Product Card -->
    <a href="/products/luna-naturals-kids" class="luna-ymal__card">
      <!-- Top: video -->
      <div class="luna-ymal__card-media">
        <video
          src="{{ 'kids-offer-video.mp4' | asset_url }}"
          autoplay
          muted
          loop
          playsinline
        ></video>
      </div>

      <!-- Bottom: details -->
      <div class="luna-ymal__card-details">
        <p class="luna-ymal__card-brand">Luna Naturals</p>
        <h3 class="luna-ymal__card-name">Kids Patches</h3>
        <p class="luna-ymal__card-tagline">Fun stickers they&rsquo;ll actually want to wear</p>

        <div class="luna-ymal__price-row">
          <span class="luna-ymal__price">$9.99</span>
          <span class="luna-ymal__compare-price">$24.99</span>
          <span class="luna-ymal__discount-badge">60% OFF</span>
        </div>
        <p class="luna-ymal__card-meta">120 patches &middot; Free shipping</p>

        <span class="luna-ymal__card-cta">Add to Order &mdash; $9.99</span>

        <p class="luna-ymal__card-guarantee">30-day money-back guarantee &middot; Cancel anytime</p>
      </div>
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Luna You May Also Like",
  "class": "luna-you-may-also-like",
  "settings": []
}
{% endschema %}
