{% comment %}
  Luna Benefits Scroll — Scroll-reveal large text statements + product image
{% endcomment %}

<style>
  .luna-benefits {
    position: relative;
    overflow: hidden;
    background: linear-gradient(to bottom, var(--gr-green, #4E5C36) 0%, var(--gr-green-mid, #3A4428) 30%, var(--gr-green, #4E5C36) 70%, var(--gr-green-dark, #2F3A1C) 100%);
  }

  .luna-benefits__inner {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 1rem 3rem;
    gap: 2.5rem;
  }

  .luna-benefits__statement {
    font-style: italic;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: -0.01em;
    color: white;
    font-size: clamp(2rem, 10vw, 3.5rem);
    opacity: 0;
    transform: translateY(60px) scale(0.9);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .luna-benefits__statement--accent {
    color: var(--gr-accent, #C45D3E);
  }

  .luna-benefits__statement--visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .luna-benefits__image-wrap {
    display: flex;
    justify-content: center;
    opacity: 0;
    transform: translateY(60px) scale(0.9);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .luna-benefits__image-wrap--visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .luna-benefits__image {
    width: 280px;
    object-fit: contain;
  }

  @media (min-width: 768px) {
    .luna-benefits__inner {
      padding: 6rem 1rem 6rem;
      gap: 4rem;
    }

    .luna-benefits__statement {
      font-size: 4.5rem;
    }

    .luna-benefits__image {
      width: 400px;
    }
  }

  @media (min-width: 1024px) {
    .luna-benefits__inner {
      gap: 5rem;
    }

    .luna-benefits__statement {
      font-size: 100px;
    }

    .luna-benefits__image {
      width: 500px;
    }
  }
</style>

<section class="luna-benefits" data-luna-benefits>
  <div class="luna-benefits__inner">
    <h2 class="luna-benefits__statement gr-display" data-luna-scroll-reveal>
      Skip The Spray
    </h2>
    <h2 class="luna-benefits__statement gr-display" data-luna-scroll-reveal>
      One Patch On
    </h2>
    <h2 class="luna-benefits__statement gr-display" data-luna-scroll-reveal>
      12 Hours of Protection
    </h2>
    <h2 class="luna-benefits__statement gr-display luna-benefits__statement--accent" data-luna-scroll-reveal>
      Plant-Powered. DEET-Free.
    </h2>

    <div class="luna-benefits__image-wrap" data-luna-scroll-reveal>
      <img
        class="luna-benefits__image"
        src="{{ 'adults-pack-moss.jpg' | asset_url }}"
        alt="Luna Naturals Mosquito Repellent Patches - Adults and Kids"
        loading="lazy"
      >
    </div>
  </div>
</section>

<script>
(function() {
  var items = document.querySelectorAll('[data-luna-scroll-reveal]');
  if (!items.length) return;

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var el = entry.target;
        if (el.classList.contains('luna-benefits__statement')) {
          el.classList.add('luna-benefits__statement--visible');
        } else if (el.classList.contains('luna-benefits__image-wrap')) {
          el.classList.add('luna-benefits__image-wrap--visible');
        }
        observer.unobserve(el);
      }
    });
  }, { threshold: 0.2 });

  items.forEach(function(item) {
    observer.observe(item);
  });
})();
</script>

{% schema %}
{
  "name": "Luna Benefits Scroll",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image (bottom)"
    },
    {
      "type": "text",
      "id": "product_image_alt",
      "label": "Product image alt text",
      "default": "Luna Naturals Mosquito Repellent Patches - Adults and Kids"
    }
  ]
}
{% endschema %}
