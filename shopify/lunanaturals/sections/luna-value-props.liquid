{% comment %}
  Luna Value Props — 3 value prop cards
  Horizontal scroll on mobile, 3-col grid on desktop
{% endcomment %}

<style>
  .luna-vp {
    background-color: var(--gr-green-dark, #2F3A1C);
    padding: 5rem 0 4rem;
  }

  .luna-vp__header {
    text-align: center;
    padding: 0 1rem;
    margin-bottom: 3rem;
  }

  .luna-vp__heading {
    font-style: italic;
    font-size: 2.25rem;
    color: white;
    line-height: 1.15;
    max-width: 56rem;
    margin: 0 auto;
  }

  .luna-vp__heading-accent {
    color: var(--gr-accent, #C45D3E);
  }

  /* Mobile: horizontal scroll with snap */
  .luna-vp__scroll {
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .luna-vp__scroll::-webkit-scrollbar {
    display: none;
  }

  .luna-vp__scroll-inner {
    display: flex;
    gap: 1rem;
    padding: 0 1rem;
    width: max-content;
  }

  .luna-vp__card-wrap--scroll {
    width: 85vw;
    max-width: 340px;
    flex-shrink: 0;
    scroll-snap-align: center;
  }

  /* Dot indicators */
  .luna-vp__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .luna-vp__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s;
  }

  .luna-vp__dot--active {
    width: 24px;
    border-radius: 999px;
    background: #fff;
  }

  /* Desktop: grid */
  .luna-vp__grid {
    display: none;
  }

  .luna-vp__card {
    background: white;
    border-radius: 1.5rem;
    overflow: hidden;
    height: 100%;
  }

  .luna-vp__card-image-wrap {
    aspect-ratio: 1 / 1;
    width: 100%;
    overflow: hidden;
    background-color: rgba(122, 128, 102, 0.2);
  }

  .luna-vp__card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .luna-vp__card-body {
    padding: 1.5rem;
  }

  .luna-vp__card-title {
    font-weight: 700;
    font-size: 1.25rem;
    text-align: center;
    color: var(--gr-dark, #1E1E1E);
    margin: 0 0 0.75rem;
  }

  .luna-vp__card-desc {
    font-size: 0.875rem;
    text-align: center;
    color: #6b7280;
    margin: 0;
    line-height: 1.625;
  }

  @media (min-width: 768px) {
    .luna-vp__heading {
      font-size: 3.75rem;
    }

    .luna-vp__header {
      margin-bottom: 4rem;
    }

    .luna-vp__card-wrap--scroll {
      width: 400px;
    }

    .luna-vp__card-body {
      padding: 2rem;
    }

    .luna-vp__card-title {
      font-size: 1.5rem;
    }

    .luna-vp__card-desc {
      font-size: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .luna-vp {
      padding-bottom: 5rem;
    }

    .luna-vp__heading {
      font-size: 4.5rem;
    }

    .luna-vp__scroll {
      display: none;
    }

    .luna-vp__dots {
      display: none;
    }

    .luna-vp__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
  }
</style>

<section class="luna-vp">
  <div class="luna-vp__header">
    <h2 class="luna-vp__heading gr-display">
      We made mosquito protection, like,
      <span class="luna-vp__heading-accent">stupidly simple.</span>
    </h2>
  </div>

  <!-- Mobile: horizontal scroll -->
  <div class="luna-vp__scroll">
    <div class="luna-vp__scroll-inner">
      <div class="luna-vp__card-wrap--scroll">
        <div class="luna-vp__card">
          <div class="luna-vp__card-image-wrap">
            <img class="luna-vp__card-image" src="{{ 'valueprop-no-mess.webp' | asset_url }}" alt="No Mess" loading="lazy">
          </div>
          <div class="luna-vp__card-body">
            <h3 class="luna-vp__card-title">No Mess</h3>
            <p class="luna-vp__card-desc">No spray. No lotion. No sticky hands. Peel one off, stick it on, walk outside. Done.</p>
          </div>
        </div>
      </div>
      <div class="luna-vp__card-wrap--scroll">
        <div class="luna-vp__card">
          <div class="luna-vp__card-image-wrap">
            <img class="luna-vp__card-image" src="{{ 'kid-running-patch.jpg' | asset_url }}" alt="Plant-Powered" loading="lazy">
          </div>
          <div class="luna-vp__card-body">
            <h3 class="luna-vp__card-title">Plant-Powered</h3>
            <p class="luna-vp__card-desc">Citronella and eucalyptus oils do the work. No DEET, no parabens, no ingredients you can't pronounce.</p>
          </div>
        </div>
      </div>
      <div class="luna-vp__card-wrap--scroll">
        <div class="luna-vp__card">
          <div class="luna-vp__card-image-wrap">
            <img class="luna-vp__card-image" src="{{ 'valueprop-built-for-real-life.webp' | asset_url }}" alt="Built for Real Life" loading="lazy">
          </div>
          <div class="luna-vp__card-body">
            <h3 class="luna-vp__card-title">Built for Real Life</h3>
            <p class="luna-vp__card-desc">Stays on during hikes, soccer practice, and playground chaos. Compact pack fits in a purse, diaper bag, or backpack.</p>
          </div>
        </div>
      </div>
    </div>
    <!-- Dots -->
    <div class="luna-vp__dots" data-luna-vp-dots>
      <button class="luna-vp__dot luna-vp__dot--active" data-vp-dot="0" aria-label="Card 1"></button>
      <button class="luna-vp__dot" data-vp-dot="1" aria-label="Card 2"></button>
      <button class="luna-vp__dot" data-vp-dot="2" aria-label="Card 3"></button>
    </div>
  </div>

  <!-- Desktop: 3-col grid -->
  <div class="luna-vp__grid">
    <div class="luna-vp__card">
      <div class="luna-vp__card-image-wrap">
        <img class="luna-vp__card-image" src="{{ 'valueprop-no-mess.webp' | asset_url }}" alt="No Mess" loading="lazy">
      </div>
      <div class="luna-vp__card-body">
        <h3 class="luna-vp__card-title">No Mess</h3>
        <p class="luna-vp__card-desc">No spray. No lotion. No sticky hands. Peel one off, stick it on, walk outside. Done.</p>
      </div>
    </div>
    <div class="luna-vp__card">
      <div class="luna-vp__card-image-wrap">
        <img class="luna-vp__card-image" src="{{ 'kid-running-patch.jpg' | asset_url }}" alt="Plant-Powered" loading="lazy">
      </div>
      <div class="luna-vp__card-body">
        <h3 class="luna-vp__card-title">Plant-Powered</h3>
        <p class="luna-vp__card-desc">Citronella and eucalyptus oils do the work. No DEET, no parabens, no ingredients you can't pronounce.</p>
      </div>
    </div>
    <div class="luna-vp__card">
      <div class="luna-vp__card-image-wrap">
        <img class="luna-vp__card-image" src="{{ 'valueprop-built-for-real-life.webp' | asset_url }}" alt="Built for Real Life" loading="lazy">
      </div>
      <div class="luna-vp__card-body">
        <h3 class="luna-vp__card-title">Built for Real Life</h3>
        <p class="luna-vp__card-desc">Stays on during hikes, soccer practice, and playground chaos. Compact pack fits in a purse, diaper bag, or backpack.</p>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var scroll = document.querySelector('.luna-vp__scroll');
  var dots = document.querySelectorAll('[data-vp-dot]');
  var cards = document.querySelectorAll('.luna-vp__card-wrap--scroll');
  if (!scroll || !cards.length) return;

  scroll.addEventListener('scroll', function() {
    var scrollLeft = scroll.scrollLeft;
    var cardWidth = cards[0].offsetWidth + 16;
    var idx = Math.round(scrollLeft / cardWidth);
    dots.forEach(function(d, i) {
      d.classList.toggle('luna-vp__dot--active', i === idx);
    });
  });

  dots.forEach(function(dot, i) {
    dot.addEventListener('click', function() {
      var cardWidth = cards[0].offsetWidth + 16;
      scroll.scrollTo({ left: cardWidth * i, behavior: 'smooth' });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Luna Value Props",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading (main)",
      "default": "We made mosquito protection, like,"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading (accent text)",
      "default": "stupidly simple."
    }
  ]
}
{% endschema %}
