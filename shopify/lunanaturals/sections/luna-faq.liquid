{% comment %}
  Luna FAQ — Accordion section
{% endcomment %}

<style>
  .luna-faq {
    background-color: var(--gr-cream, #F5F0E8);
    padding: 4rem 0 4rem;
    border-top: 1px solid rgba(30, 30, 30, 0.05);
  }

  .luna-faq__inner {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .luna-faq__heading {
    font-size: 1.875rem;
    color: var(--gr-dark, #1E1E1E);
    text-align: center;
    line-height: 1.2;
    margin: 0 0 2.5rem;
  }

  .luna-faq__item {
    border-bottom: 1px solid rgba(30, 30, 30, 0.15);
  }

  .luna-faq__question {
    width: 100%;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    text-align: left;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
  }

  .luna-faq__question-text {
    font-weight: 700;
    font-size: 1rem;
    color: var(--gr-dark, #1E1E1E);
    line-height: 1.4;
  }

  .luna-faq__toggle {
    font-size: 1.5rem;
    color: var(--gr-dark, #1E1E1E);
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.125rem;
    transition: transform 0.2s ease;
    user-select: none;
  }

  .luna-faq__item--open .luna-faq__toggle {
    transform: rotate(45deg);
  }

  .luna-faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .luna-faq__item--open .luna-faq__answer {
    max-height: 500px;
  }

  .luna-faq__answer-text {
    font-size: 0.875rem;
    color: var(--gr-sage, #7A8066);
    line-height: 1.625;
    padding-bottom: 1.25rem;
    margin: -0.25rem 0 0;
  }

  @media (min-width: 768px) {
    .luna-faq {
      padding: 5rem 0;
    }

    .luna-faq__heading {
      font-size: 2.25rem;
    }
  }

  @media (min-width: 1024px) {
    .luna-faq__inner {
      max-width: 780px;
    }
  }
</style>

<section class="luna-faq" data-section-type="luna-faq">
  <div class="luna-faq__inner">
    <h2 class="luna-faq__heading gr-display">
      Any last questions?
    </h2>

    <div data-luna-faq-list>
      <div class="luna-faq__item" data-luna-faq-item>
        <button class="luna-faq__question" data-luna-faq-trigger aria-expanded="false">
          <span class="luna-faq__question-text">What are Luna Naturals Mosquito Repellent Patches?</span>
          <span class="luna-faq__toggle">+</span>
        </button>
        <div class="luna-faq__answer" data-luna-faq-answer>
          <p class="luna-faq__answer-text">Luna Naturals patches are plant-based mosquito repellent stickers that use citronella and eucalyptus essential oils to keep bugs away. Just peel, stick on clothing, and enjoy up to 12 hours of DEET-free protection.</p>
        </div>
      </div>
      <div class="luna-faq__item" data-luna-faq-item>
        <button class="luna-faq__question" data-luna-faq-trigger aria-expanded="false">
          <span class="luna-faq__question-text">I'm subscribed. How do I get patches on my next order?</span>
          <span class="luna-faq__toggle">+</span>
        </button>
        <div class="luna-faq__answer" data-luna-faq-answer>
          <p class="luna-faq__answer-text">Your subscription automatically ships every 3 months. You can manage your subscription, skip a delivery, or add extra packs from your account dashboard at any time.</p>
        </div>
      </div>
      <div class="luna-faq__item" data-luna-faq-item>
        <button class="luna-faq__question" data-luna-faq-trigger aria-expanded="false">
          <span class="luna-faq__question-text">When will my patches arrive?</span>
          <span class="luna-faq__toggle">+</span>
        </button>
        <div class="luna-faq__answer" data-luna-faq-answer>
          <p class="luna-faq__answer-text">Standard orders ship within 1-2 business days and arrive in 3-5 business days. Orders of 2+ packs ship free. You'll receive tracking info via email as soon as your order ships.</p>
        </div>
      </div>
      <div class="luna-faq__item" data-luna-faq-item>
        <button class="luna-faq__question" data-luna-faq-trigger aria-expanded="false">
          <span class="luna-faq__question-text">What's inside each order? What am I getting?</span>
          <span class="luna-faq__toggle">+</span>
        </button>
        <div class="luna-faq__answer" data-luna-faq-answer>
          <p class="luna-faq__answer-text">Each pack contains 90 individual patches &mdash; enough to cover a family of four for the entire summer. Patches come in fun, kid-friendly designs and are individually sealed for freshness.</p>
        </div>
      </div>
      <div class="luna-faq__item" data-luna-faq-item>
        <button class="luna-faq__question" data-luna-faq-trigger aria-expanded="false">
          <span class="luna-faq__question-text">How long does each patch last?</span>
          <span class="luna-faq__toggle">+</span>
        </button>
        <div class="luna-faq__answer" data-luna-faq-answer>
          <p class="luna-faq__answer-text">Each patch provides up to 12 hours of continuous protection. For best results, apply to clothing rather than directly on skin. Replace after 12 hours or after heavy rain exposure.</p>
        </div>
      </div>
      <div class="luna-faq__item" data-luna-faq-item>
        <button class="luna-faq__question" data-luna-faq-trigger aria-expanded="false">
          <span class="luna-faq__question-text">How do you handle returns?</span>
          <span class="luna-faq__toggle">+</span>
        </button>
        <div class="luna-faq__answer" data-luna-faq-answer>
          <p class="luna-faq__answer-text">We offer a 30-day money-back guarantee &mdash; no questions asked. If you're not completely satisfied, contact us for a full refund. We'll even cover return shipping.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Luna FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Any last questions?"
    }
  ]
}
{% endschema %}
