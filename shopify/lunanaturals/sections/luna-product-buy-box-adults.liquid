<script>
(function() {
  /* ===== Gallery ===== */
  var galleryWrap = document.querySelector('[data-gallery]');
  if (!galleryWrap) return;

  var images = galleryWrap.querySelectorAll('[data-gallery-image]');
  var dots = galleryWrap.querySelectorAll('[data-gallery-dot]');
  var thumbs = galleryWrap.querySelectorAll('[data-gallery-thumb]');
  var featureTags = galleryWrap.querySelector('[data-feature-tags]');
  var overlay3pack = galleryWrap.querySelector('[data-overlay-3pack]');
  var baBefore = galleryWrap.querySelector('[data-ba-before]');
  var baAfter = galleryWrap.querySelector('[data-ba-after]');
  var currentIdx = 0;
  var total = images.length;

  function showImage(idx) {
    currentIdx = ((idx % total) + total) % total;
    images.forEach(function(img, i) {
      img.classList.toggle('luna-bb__gallery-image--active', i === currentIdx);
    });
    dots.forEach(function(dot, i) {
      dot.classList.toggle('luna-bb__dot--active', i === currentIdx);
    });
    thumbs.forEach(function(thumb, i) {
      thumb.classList.toggle('luna-bb__thumb--active', i === currentIdx);
    });
    /* Feature tags only on image 0 */
    if (featureTags) featureTags.style.display = currentIdx === 0 ? 'block' : 'none';
    /* 3-pack overlay on image 2 */
    if (overlay3pack) overlay3pack.setAttribute('data-visible', currentIdx === 2 ? 'true' : 'false');
    /* Before/After on image 1 */
    if (baBefore) baBefore.style.display = currentIdx === 1 ? 'block' : 'none';
    if (baAfter) baAfter.style.display = currentIdx === 1 ? 'block' : 'none';
  }

  galleryWrap.querySelector('[data-gallery-prev]').addEventListener('click', function() { showImage(currentIdx - 1); });
  galleryWrap.querySelector('[data-gallery-next]').addEventListener('click', function() { showImage(currentIdx + 1); });
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() { showImage(parseInt(this.getAttribute('data-gallery-dot'))); });
  });
  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() { showImage(parseInt(this.getAttribute('data-gallery-thumb'))); });
  });

  /* ===== Info Tabs ===== */
  var tabBtns = document.querySelectorAll('[data-info-tab]');
  var tabPanels = document.querySelectorAll('[data-info-panel]');
  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = this.getAttribute('data-info-tab');
      tabBtns.forEach(function(b) { b.classList.toggle('luna-bb__info-tab--active', b.getAttribute('data-info-tab') === key); });
      tabPanels.forEach(function(p) { p.classList.toggle('luna-bb__info-panel--active', p.getAttribute('data-info-panel') === key); });
    });
  });

  /* ===== Bundle Selector ===== */
  var bundleBtns = document.querySelectorAll('[data-bundle]');
  bundleBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      bundleBtns.forEach(function(b) { b.classList.remove('luna-bb__bundle--active'); });
      this.classList.add('luna-bb__bundle--active');
    });
  });

  /* ===== Subscribe Toggle ===== */
  var subToggle = document.querySelector('[data-subscribe-toggle]');
  var subWrap = document.querySelector('[data-subscribe-wrap]');
  if (subToggle) {
    subToggle.addEventListener('click', function() {
      this.classList.toggle('luna-bb__toggle--on');
      subWrap.classList.toggle('luna-bb__subscribe--active');
    });
  }

  /* ===== Countdown Timer ===== */
  var countdownEl = document.querySelector('[data-countdown]');
  if (countdownEl) {
    var hrs = 5, min = 11, sec = 26;
    setInterval(function() {
      sec--;
      if (sec < 0) { sec = 59; min--; }
      if (min < 0) { min = 59; hrs--; }
      if (hrs < 0) { hrs = 0; min = 0; sec = 0; }
      var pad = function(n) { return String(n).padStart(2, '0'); };
      countdownEl.textContent = pad(hrs) + 'h ' + pad(min) + 'm ' + pad(sec) + 's';
    }, 1000);
  }
})();
</script>

