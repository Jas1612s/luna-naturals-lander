                </div>
              </div>
              <div class="luna-bb__step">
                <span class="luna-bb__step-num luna-bb__step-num--3">3</span>
                <div>
                  <p class="luna-bb__step-title">Protect</p>
                  <p class="luna-bb__step-desc">12 hours of plant-based protection</p>
                </div>
              </div>
            </div>

            {%- comment -%} Reviews {%- endcomment -%}
            <div class="luna-bb__info-panel" data-bb-info-panel="reviews">
              <div class="luna-bb__mini-review">
                <div class="luna-bb__mini-avatar">RD</div>
                <div>
                  <div class="luna-bb__mini-header">
                    <span class="luna-bb__mini-name">Rebecca D.</span>
                    <div class="luna-bb__mini-stars">
                      {% for i in (1..5) %}<svg width="12" height="12" viewBox="0 0 20 20" fill="var(--gr-gold)"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/></svg>{% endfor %}
                    </div>
                    <span class="luna-bb__mini-verified">Verified</span>
                  </div>
                  <p class="luna-bb__mini-quote">&ldquo;Zero bites all summer. Never going back to spray.&rdquo;</p>
                </div>
              </div>
              <div class="luna-bb__mini-review">
                <div class="luna-bb__mini-avatar">JH</div>
                <div>
                  <div class="luna-bb__mini-header">
                    <span class="luna-bb__mini-name">Jeremy H.</span>
                    <div class="luna-bb__mini-stars">
                      {% for i in (1..5) %}<svg width="12" height="12" viewBox="0 0 20 20" fill="var(--gr-gold)"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/></svg>{% endfor %}
                    </div>
                    <span class="luna-bb__mini-verified">Verified</span>
                  </div>
                  <p class="luna-bb__mini-quote">&ldquo;One pack lasts the whole season for under $15.&rdquo;</p>
                </div>
              </div>
              <div class="luna-bb__mini-review">
                <div class="luna-bb__mini-avatar">SM</div>
                <div>
                  <div class="luna-bb__mini-header">
                    <span class="luna-bb__mini-name">Sarah M.</span>
                    <div class="luna-bb__mini-stars">
                      {% for i in (1..5) %}<svg width="12" height="12" viewBox="0 0 20 20" fill="var(--gr-gold)"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/></svg>{% endfor %}
                    </div>
                    <span class="luna-bb__mini-verified">Verified</span>
                  </div>
                  <p class="luna-bb__mini-quote">&ldquo;My toddler thinks they&rsquo;re stickers. Zero bites in 3 weeks.&rdquo;</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        {%- comment -%} ── Pick your supply ── {%- endcomment -%}
        <p class="luna-bb__supply-label">Pick your supply</p>
        <div class="luna-bb__bundle-grid" data-luna-bb-bundles>
          <button class="luna-bb__bundle-card luna-bb__bundle-card--active" data-bb-bundle="2">
            <div class="luna-bb__bundle-tags">
              <span class="luna-bb__bundle-tag luna-bb__bundle-tag--save">Save 48%</span>
            </div>
            <p class="luna-bb__bundle-name">2-Pack</p>
            <p class="luna-bb__bundle-meta">180 patches &middot; 2-mo supply</p>
            <p class="luna-bb__bundle-price">$25.98</p>
            <p class="luna-bb__bundle-compare">$49.98</p>
            <div class="luna-bb__bundle-per">
              <p class="luna-bb__bundle-per-text">$12.99/pack</p>
            </div>
          </button>

          <button class="luna-bb__bundle-card" data-bb-bundle="4">
            <div class="luna-bb__bundle-tags">
              <span class="luna-bb__bundle-tag luna-bb__bundle-tag--best">Best Value</span>
              <span class="luna-bb__bundle-tag luna-bb__bundle-tag--save">Save 64%</span>
            </div>
            <p class="luna-bb__bundle-name">4-Pack</p>
            <p class="luna-bb__bundle-meta">360 patches &middot; 4-mo supply</p>
            <p class="luna-bb__bundle-price">$35.96</p>
            <p class="luna-bb__bundle-compare">$99.96</p>
            <div class="luna-bb__bundle-per">
              <p class="luna-bb__bundle-per-text">$8.99/pack</p>
            </div>
          </button>
        </div>

        {%- comment -%} ── Subscribe & Save toggle ── {%- endcomment -%}
        <div class="luna-bb__subscribe luna-bb__subscribe--active" data-luna-bb-subscribe>
          <div class="luna-bb__subscribe-row">
            <div class="luna-bb__subscribe-left">
              <div class="luna-bb__subscribe-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
              </div>
              <div>
                <p class="luna-bb__subscribe-title">
                  Subscribe &amp; save <span class="luna-bb__subscribe-pct">20%</span>
                  <span class="luna-bb__subscribe-best">Best Value</span>
                </p>
                <p class="luna-bb__subscribe-desc">Every 3 months &middot; skip, edit, or cancel anytime</p>
              </div>
            </div>
            <button class="luna-bb__toggle luna-bb__toggle--on" data-bb-subscribe-toggle aria-label="Toggle subscribe and save">
              <div class="luna-bb__toggle-knob"></div>
            </button>
          </div>
        </div>

        {%- comment -%} ── Cross-sell ── {%- endcomment -%}
        <div class="luna-bb__cross-sell">
          <div class="luna-bb__cross-sell-img-wrap">
            <img class="luna-bb__cross-sell-img" src="{{ 'product-kids-patches-v2.jpg' | asset_url }}" alt="Add Kids Patches" loading="lazy">
          </div>
          <div class="luna-bb__cross-sell-body">
            <p class="luna-bb__cross-sell-name">Add Kids Patches</p>
            <p class="luna-bb__cross-sell-price">
              <span class="luna-bb__cross-sell-price-accent">+$9.99</span>
              <span class="luna-bb__cross-sell-price-old">$24.99</span>
              &middot; <span class="luna-bb__cross-sell-price-save">save $15</span>
            </p>
            <p class="luna-bb__cross-sell-meta">120 patches &middot; fun designs kids love</p>
          </div>
          <button class="luna-bb__cross-sell-add" aria-label="Add cross-sell item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gr-dark)" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
        </div>

        {%- comment -%} ── CTA ── {%- endcomment -%}
        <button class="luna-bb__cta" data-bb-cta>
          <p class="luna-bb__cta-main gr-display">Claim deal &middot; Save <span data-bb-cta-pct>60</span>%</p>
          <p class="luna-bb__cta-sub">
            Skip to checkout — total <strong data-bb-cta-total>$9.99</strong>
            <span class="luna-bb__cta-sub-old" data-bb-cta-compare>$24.99</span>
          </p>
        </button>

        {%- comment -%} ── Shipping info ── {%- endcomment -%}
        <div class="luna-bb__shipping">
          <div class="luna-bb__shipping-row">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gr-green)"><circle cx="12" cy="12" r="6"/></svg>
            <span class="luna-bb__shipping-stock">In stock</span>
            <span class="luna-bb__shipping-detail">&middot; Expected delivery in 2-3 days</span>
          </div>
          <div class="luna-bb__shipping-row">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span class="luna-bb__shipping-date">Ships next business day from our California warehouse</span>
          </div>
        </div>

        {%- comment -%} ── Deal timer ── {%- endcomment -%}
        <div class="luna-bb__timer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gr-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <p class="luna-bb__timer-text">Deal locks in <span class="luna-bb__timer-bold" data-bb-countdown>5h 11m 26s</span></p>
        </div>

        {%- comment -%} ── Free shipping progress ── {%- endcomment -%}
        <div class="luna-bb__free-ship">
          <div class="luna-bb__free-ship-header">
            <p class="luna-bb__free-ship-text" data-bb-ship-text>
              <span class="luna-bb__free-ship-green">You qualify for free shipping!</span>
            </p>
            <span class="luna-bb__free-ship-pct" data-bb-ship-pct>100%</span>
          </div>
          <div class="luna-bb__free-ship-bar">
            <div class="luna-bb__free-ship-fill luna-bb__free-ship-fill--qualified" data-bb-ship-bar style="width: 100%;"></div>
          </div>
          <p class="luna-bb__free-ship-note">Ships next business day &middot; Free returns within 60 days</p>
        </div>

        {%- comment -%} ── Trust badges ── {%- endcomment -%}
        <div class="luna-bb__trust">
          {% assign trust_items = "30-day money-back guarantee,Free US shipping over $30,Delivered in 2-3 business days,Pediatrician reviewed & approved" | split: "," %}
          {% for badge in trust_items %}
            <p class="luna-bb__trust-item">
              <svg class="luna-bb__trust-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg>
              {{ badge }}
            </p>
          {% endfor %}
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Luna Product Buy Box",
  "settings": [
    {
      "type": "text",
      "id": "product_title",
      "label": "Product title",
      "default": "Luna Naturals Mosquito Repellent Patches \u2014 Adults"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Plant-powered protection for the whole family. One pack covers your entire summer."
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating text",
      "default": "4.8/5.0 (50,000+ reviews)"
    },
    {
      "type": "text",
      "id": "ship_date",
      "label": "Shipping date text",
      "default": "Ships next business day from our California warehouse"
    },
    {
      "type": "range",
      "id": "countdown_hours",
      "label": "Countdown hours",
      "min": 1,
      "max": 24,
      "default": 5
    },
    {
      "type": "range",
      "id": "countdown_minutes",
      "label": "Countdown minutes",
      "min": 0,
      "max": 59,
      "default": 11
    }
  ]
}
{% endschema %}
