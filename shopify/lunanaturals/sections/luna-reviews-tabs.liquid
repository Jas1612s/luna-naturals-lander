<style>
  .luna-reviews-tabs {
    background: var(--gr-green-dark, #1e3a24);
    padding: 64px 0 80px;
    overflow: hidden;
  }

  .luna-reviews-tabs__header {
    text-align: center;
    padding: 0 16px;
  }

  .luna-reviews-tabs__stars-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .luna-reviews-tabs__stars { display: flex; gap: 2px; }

  .luna-reviews-tabs__stars-text {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
  }

  .luna-reviews-tabs__title {
    font-style: italic;
    font-size: 30px;
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
  }

  /* Testimonials carousel */
  .luna-reviews-tabs__testimonials {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    margin-top: 48px;
  }

  .luna-reviews-tabs__testimonial {
    max-width: 600px;
    text-align: center;
  }

  .luna-reviews-tabs__testimonial-img {
    width: 80px;
    height: 80px;
    border-radius: 9999px;
    object-fit: cover;
    margin: 0 auto 20px;
    border: 3px solid rgba(255, 255, 255, 0.15);
    display: block;
  }

  .luna-reviews-tabs__testimonial-quote {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .luna-reviews-tabs__testimonial-name {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
  }

  .luna-reviews-tabs__testimonial-designation {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 20px;
  }

  .luna-reviews-tabs__nav {
    display: flex;
    justify-content: center;
    gap: 12px;
  }

  .luna-reviews-tabs__nav-btn {
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s;
  }

  .luna-reviews-tabs__nav-btn:hover { background: var(--gr-accent, #c1440e); }

  /* UGC Video carousel */
  .luna-reviews-tabs__ugc {
    margin-top: 64px;
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .luna-reviews-tabs__ugc::-webkit-scrollbar { display: none; }

  .luna-reviews-tabs__ugc-inner {
    display: flex;
    gap: 16px;
    padding: 0 24px 16px;
    width: max-content;
  }

  .luna-reviews-tabs__ugc-card {
    width: 200px;
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
  }

  .luna-reviews-tabs__ugc-video {
    aspect-ratio: 9 / 16;
    position: relative;
  }

  .luna-reviews-tabs__ugc-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .luna-reviews-tabs__ugc-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .luna-reviews-tabs__ugc-play-circle {
    width: 48px;
    height: 48px;
    border-radius: 9999px;
    background: rgba(193, 68, 14, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .luna-reviews-tabs__ugc-meta {
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .luna-reviews-tabs__ugc-quote {
    font-size: 14px;
    font-weight: 500;
    color: var(--gr-dark, #1a1a1a);
    line-height: 1.4;
  }

  .luna-reviews-tabs__ugc-tiktok { flex-shrink: 0; opacity: 0.4; }

  @media (min-width: 768px) {
    .luna-reviews-tabs { padding: 96px 0 112px; }
    .luna-reviews-tabs__header { padding: 0 24px; }
    .luna-reviews-tabs__title { font-size: 48px; }
    .luna-reviews-tabs__testimonials { margin-top: 64px; padding: 0 24px; }
    .luna-reviews-tabs__ugc { margin-top: 80px; }
    .luna-reviews-tabs__ugc-card { width: 220px; }
  }
</style>

<section class="luna-reviews-tabs" data-section-type="luna-reviews-tabs">
  <!-- Header -->
  <div class="luna-reviews-tabs__header">
    <div class="luna-reviews-tabs__stars-row">
      <div class="luna-reviews-tabs__stars">
        {% for i in (1..5) %}
          <svg width="18" height="18" viewBox="0 0 20 20" fill="var(--gr-accent)"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.51.91-5.32L2.27 6.69l5.34-.78L10 1z"/></svg>
        {% endfor %}
      </div>
      <span class="luna-reviews-tabs__stars-text">4.8 stars from 50,000+ reviews</span>
    </div>
    <h2 class="luna-reviews-tabs__title">Join 50,000+ Families<br>Ditching the Spray</h2>
  </div>

  <!-- Testimonials -->
  <div class="luna-reviews-tabs__testimonials">
    <div class="luna-reviews-tabs__testimonial" data-testimonial-container>
      <img class="luna-reviews-tabs__testimonial-img" data-testimonial-img src="{{ 'review-patch-arm.jpg' | prepend: '/images/gruns/' | asset_url }}" alt="Review" />
      <p class="luna-reviews-tabs__testimonial-quote" data-testimonial-quote>&ldquo;I just stick one on my arm before heading outside and forget about it. 12 hours later, zero bites. It's honestly the simplest thing I've ever used.&rdquo;</p>
      <p class="luna-reviews-tabs__testimonial-name" data-testimonial-name>Jeremy H.</p>
      <p class="luna-reviews-tabs__testimonial-designation" data-testimonial-designation>Subscriber Since 2025 &bull; Verified Buyer</p>
      <div class="luna-reviews-tabs__nav">
        <button class="luna-reviews-tabs__nav-btn" data-testimonial-prev aria-label="Previous testimonial">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="luna-reviews-tabs__nav-btn" data-testimonial-next aria-label="Next testimonial">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- UGC videos -->
  <div class="luna-reviews-tabs__ugc">
    <div class="luna-reviews-tabs__ugc-inner">
      {% assign ugc_quotes = "Best purchase this year,Never going back to DEET,The whole family loves them,Finally something that works,Our camping trip essential,Way better than spray,My kids beg me for these,Zero bites all summer long" | split: "," %}
      {% assign ugc_videos = "ugc-102925.mp4,ugc-102918.mp4,ugc-102910.mp4,ugc-102903.mp4,ugc-102855.mp4,ugc-102233.mp4,ugc-102224.mp4,ugc-102216.mp4" | split: "," %}
      {% for vid in ugc_videos %}
        <div class="luna-reviews-tabs__ugc-card">
          <div class="luna-reviews-tabs__ugc-video">
            <video src="{{ vid | prepend: '/videos/gruns/' | asset_url }}" muted loop playsinline preload="metadata"></video>
            <div class="luna-reviews-tabs__ugc-play">
              <div class="luna-reviews-tabs__ugc-play-circle">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
          </div>
          <div class="luna-reviews-tabs__ugc-meta">
            <p class="luna-reviews-tabs__ugc-quote">&ldquo;{{ ugc_quotes[forloop.index0] }}&rdquo;</p>
            <div class="luna-reviews-tabs__ugc-tiktok">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.7a8.18 8.18 0 0 0 4.76 1.52v-3.4a4.85 4.85 0 0 1-1-.13z"/></svg>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
(function() {
  var section = document.querySelector('[data-section-type="luna-reviews-tabs"]');
  if (!section) return;

  var testimonials = [
    { quote: "I just stick one on my arm before heading outside and forget about it. 12 hours later, zero bites. It\u2019s honestly the simplest thing I\u2019ve ever used.", name: "Jeremy H.", designation: "Subscriber Since 2025 \u2022 Verified Buyer", src: "/images/gruns/review-patch-arm.jpg" },
    { quote: "I was spending $40+ a month on sprays that barely worked. One box of these lasts the whole season for less than $15. The quality is incredible.", name: "Lisa C.", designation: "Outdoor Enthusiast \u2022 Verified Buyer", src: "/images/gruns/review-woman-box.jpg" },
    { quote: "My toddler thinks they\u2019re dinosaur stickers and wants to put them on herself every morning. Three weeks, zero bites. The fun designs are such a smart touch!", name: "Sarah M.", designation: "Mom of 2 \u2022 Verified Buyer", src: "/images/gruns/review-mom-toddler.jpg" },
    { quote: "Took these on a 4-day hiking trip. We used maybe 20 patches total for both of us. Not a single bite the entire trip. Absolute must-have for the outdoors.", name: "Rebecca D.", designation: "Adventure Couple \u2022 Verified Buyer", src: "/images/gruns/review-hikers.jpg" }
  ];

  var idx = 0;
  var imgEl = section.querySelector('[data-testimonial-img]');
  var quoteEl = section.querySelector('[data-testimonial-quote]');
  var nameEl = section.querySelector('[data-testimonial-name]');
  var desigEl = section.querySelector('[data-testimonial-designation]');

  function show(i) {
    idx = ((i % testimonials.length) + testimonials.length) % testimonials.length;
    var t = testimonials[idx];
    if (imgEl) imgEl.src = t.src;
    if (quoteEl) quoteEl.innerHTML = '&ldquo;' + t.quote + '&rdquo;';
    if (nameEl) nameEl.textContent = t.name;
    if (desigEl) desigEl.textContent = t.designation;
  }

  section.querySelector('[data-testimonial-prev]').addEventListener('click', function() { show(idx - 1); });
  section.querySelector('[data-testimonial-next]').addEventListener('click', function() { show(idx + 1); });
  setInterval(function() { show(idx + 1); }, 6000);
})();
</script>

{% schema %}
{
  "name": "Luna Reviews Tabs",
  "tag": "section",
  "class": "luna-reviews-tabs-section",
  "settings": []
}
{% endschema %}
