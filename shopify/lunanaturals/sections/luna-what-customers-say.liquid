{% comment %}
  Luna Naturals — What Customers Say
  Category-filtered testimonials: Families, Outdoors, Kids, Ingredients, Value
{% endcomment %}

<style>
  .luna-wcs {
    background: var(--gr-green-dark, #1b3a26);
    padding: 56px 16px;
  }
  @media (min-width: 768px) {
    .luna-wcs { padding: 64px 24px; }
  }

  .luna-wcs__container {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .luna-wcs__label {
    font-size: 10px;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 20px;
  }

  .luna-wcs__quote {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
    line-height: 1.6;
    margin-bottom: 4px;
    font-style: italic;
  }
  @media (min-width: 768px) {
    .luna-wcs__quote { font-size: 18px; }
  }

  .luna-wcs__author {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 24px;
  }

  .luna-wcs__tabs {
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .luna-wcs__tabs::-webkit-scrollbar { display: none; }

  .luna-wcs__tabs-inner {
    display: flex;
    gap: 8px;
    width: max-content;
    margin: 0 auto;
  }

  .luna-wcs__tab {
    padding: 8px 20px;
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.6);
    background: transparent;
    transition: all 0.2s;
  }
  .luna-wcs__tab:hover {
    border-color: rgba(255,255,255,0.4);
  }
  .luna-wcs__tab--active {
    border: 2px solid var(--gr-accent, #c0392b);
    color: var(--gr-accent, #c0392b);
  }

  /* Quote panels */
  .luna-wcs__panel { display: none; }
  .luna-wcs__panel--active { display: block; }
</style>

<section class="luna-wcs">
  <div class="luna-wcs__container">
    <p class="luna-wcs__label">What Customers Say</p>

    <!-- Testimonial panels -->
    <div class="luna-wcs__panel luna-wcs__panel--active" data-wcs-panel="families">
      <p class="luna-wcs__quote">&ldquo;Stuck one on each kid before the park &mdash; zero bites. I&rsquo;m literally never going back to spray. These are a game-changer for our family.&rdquo;</p>
      <p class="luna-wcs__author">&mdash; Rebecca D. 34</p>
    </div>
    <div class="luna-wcs__panel" data-wcs-panel="outdoors">
      <p class="luna-wcs__quote">&ldquo;Took these on a 4-day camping trip. Not a single bite the entire trip for any of us. The patches stayed on even while hiking in the heat.&rdquo;</p>
      <p class="luna-wcs__author">&mdash; Marcus T. 41</p>
    </div>
    <div class="luna-wcs__panel" data-wcs-panel="kids">
      <p class="luna-wcs__quote">&ldquo;My toddler thinks they&rsquo;re dinosaur stickers and wants to put them on himself every morning. Three weeks, zero bites. Absolute parent win.&rdquo;</p>
      <p class="luna-wcs__author">&mdash; Sarah M. 29</p>
    </div>
    <div class="luna-wcs__panel" data-wcs-panel="ingredients">
      <p class="luna-wcs__quote">&ldquo;As someone with eczema, I can&rsquo;t use DEET products. These don&rsquo;t touch my skin directly and the citronella oil actually keeps bugs away.&rdquo;</p>
      <p class="luna-wcs__author">&mdash; Amanda K. 37</p>
    </div>
    <div class="luna-wcs__panel" data-wcs-panel="value">
      <p class="luna-wcs__quote">&ldquo;I used to spend $40+ a month on sprays, candles, and coils in summer. One pack of these lasts the whole season for under $15. No-brainer.&rdquo;</p>
      <p class="luna-wcs__author">&mdash; Jeremy H. 45</p>
    </div>

    <!-- Category tabs -->
    <div class="luna-wcs__tabs">
      <div class="luna-wcs__tabs-inner">
        <button class="luna-wcs__tab luna-wcs__tab--active" data-wcs-tab="families">Families</button>
        <button class="luna-wcs__tab" data-wcs-tab="outdoors">Outdoors</button>
        <button class="luna-wcs__tab" data-wcs-tab="kids">Kids</button>
        <button class="luna-wcs__tab" data-wcs-tab="ingredients">Ingredients</button>
        <button class="luna-wcs__tab" data-wcs-tab="value">Value</button>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var tabs = document.querySelectorAll('[data-wcs-tab]');
  var panels = document.querySelectorAll('[data-wcs-panel]');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var key = this.getAttribute('data-wcs-tab');
      tabs.forEach(function(t) { t.classList.toggle('luna-wcs__tab--active', t.getAttribute('data-wcs-tab') === key); });
      panels.forEach(function(p) { p.classList.toggle('luna-wcs__panel--active', p.getAttribute('data-wcs-panel') === key); });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Luna What Customers Say",
  "tag": "section",
  "class": "luna-what-customers-say",
  "settings": []
}
{% endschema %}
