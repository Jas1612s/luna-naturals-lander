<style>
  .luna-safe {
    background: var(--gr-cream-warm, #f0ebe0);
    padding: 64px 16px;
  }

  .luna-safe__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .luna-safe__eyebrow {
    font-size: 12px;
    font-weight: 700;
    color: var(--gr-accent, #c1440e);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 8px;
  }

  .luna-safe__title {
    font-style: italic;
    font-size: 30px;
    font-weight: 700;
    color: var(--gr-dark, #1a1a1a);
    line-height: 1.15;
    margin-bottom: 8px;
  }

  .luna-safe__subtitle {
    font-size: 14px;
    color: var(--gr-sage, #7c8c78);
    max-width: 384px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Mobile: stacked */
  .luna-safe__cards-mobile {
    max-width: 420px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .luna-safe__cards-desktop {
    display: none;
  }

  /* Card */
  .luna-safe__card {
    background: var(--gr-green-dark, #1e3a24);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .luna-safe__card-icon {
    width: 56px;
    height: 56px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .luna-safe__card-title {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .luna-safe__card-desc {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    max-width: 280px;
  }

  /* Fade-in animation */
  .luna-safe__fade {
    opacity: 0;
    transform: translateY(40px) scale(0.95);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .luna-safe__fade--visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (min-width: 768px) {
    .luna-safe {
      padding: 96px 24px;
    }

    .luna-safe__header {
      margin-bottom: 56px;
    }

    .luna-safe__title {
      font-size: 36px;
    }

    .luna-safe__cards-mobile {
      display: none;
    }

    .luna-safe__cards-desktop {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      max-width: 960px;
      margin: 0 auto;
    }

    .luna-safe__card {
      height: 100%;
    }

    .luna-safe__card-desc {
      max-width: 260px;
    }
  }

  @media (min-width: 1024px) {
    .luna-safe__cards-desktop {
      max-width: 1100px;
      gap: 20px;
    }
  }
</style>

