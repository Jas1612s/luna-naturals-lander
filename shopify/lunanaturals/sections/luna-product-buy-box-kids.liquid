        <div class="luna-buy-box__subscribe luna-buy-box__subscribe--active" data-subscribe>
          <div class="luna-buy-box__subscribe-inner">
            <div class="luna-buy-box__subscribe-left">
              <div class="luna-buy-box__subscribe-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
              </div>
              <div>
                <p class="luna-buy-box__subscribe-title">Subscribe &amp; save <span class="accent">20%</span> <span class="luna-buy-box__subscribe-best-value">Best Value</span></p>
                <p class="luna-buy-box__subscribe-sub">Every 3 months &middot; skip, edit, or cancel anytime</p>
              </div>
            </div>
            <button class="luna-buy-box__toggle luna-buy-box__toggle--on" data-subscribe-toggle aria-label="Toggle subscription">
              <div class="luna-buy-box__toggle-knob"></div>
            </button>
          </div>
        </div>

        <!-- Cross-sell -->
        <div class="luna-buy-box__cross-sell">
          <div class="luna-buy-box__cross-sell-img">
            <img src="{{ 'adults-pack-moss.jpg' | prepend: '/images/gruns/' | asset_url }}" alt="Adults Patches" width="64" height="64" loading="lazy" />
          </div>
          <div class="luna-buy-box__cross-sell-info">
            <p class="luna-buy-box__cross-sell-name">Add Adults Patches</p>
            <p class="luna-buy-box__cross-sell-price"><span class="bold">+$9.99</span> <span class="strike">$24.99</span> &middot; <span class="save">save $15</span></p>
            <p class="luna-buy-box__cross-sell-sub">90 patches &middot; protect the whole family</p>
          </div>
          <button class="luna-buy-box__cross-sell-add" aria-label="Add to order">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gr-dark)" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
        </div>

        <!-- CTA -->
        <button class="luna-buy-box__cta" data-cta>
          <p class="luna-buy-box__cta-main">Claim deal &middot; Save 60%</p>
          <p class="luna-buy-box__cta-sub">Skip to checkout &mdash; total <strong data-cta-price>$9.99</strong> <span class="strike" data-cta-compare>$24.99</span></p>
        </button>

        <!-- Shipping -->
        <div class="luna-buy-box__shipping">
          <p class="luna-buy-box__shipping-line luna-buy-box__shipping-line--stock">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gr-green)"><circle cx="12" cy="12" r="6"/></svg>
            <span class="green">In stock</span>
            <span class="dark">&middot; Expected delivery in 2&ndash;3 days</span>
          </p>
          <p class="luna-buy-box__shipping-line green">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span class="green">Ships Mon, Jun 9 from our California warehouse</span>
          </p>
        </div>

        <!-- Timer -->
        <div class="luna-buy-box__timer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gr-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <p class="luna-buy-box__timer-text">Deal locks in <strong data-countdown>5h 11m 26s</strong></p>
        </div>

        <!-- Free shipping progress -->
        <div class="luna-buy-box__free-ship" data-free-ship>
          <div class="luna-buy-box__free-ship-header">
            <p class="luna-buy-box__free-ship-msg"><span class="green-bold">You qualify for free shipping!</span></p>
            <span class="luna-buy-box__free-ship-pct">100%</span>
          </div>
          <div class="luna-buy-box__free-ship-bar">
            <div class="luna-buy-box__free-ship-fill luna-buy-box__free-ship-fill--green" style="width: 100%"></div>
          </div>
          <p class="luna-buy-box__free-ship-note">Ships next business day &middot; Free returns within 60 days</p>
        </div>

        <!-- Trust badges -->
        <div class="luna-buy-box__trust-badges">
          <p class="luna-buy-box__trust-badge"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg> 30-day money-back guarantee</p>
          <p class="luna-buy-box__trust-badge"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg> Free US shipping over $30</p>
          <p class="luna-buy-box__trust-badge"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg> Delivered in 2&ndash;3 business days</p>
          <p class="luna-buy-box__trust-badge"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gr-green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4 12 14.01l-3-3"/></svg> Pediatrician reviewed &amp; approved</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var section = document.querySelector('[data-section-type="luna-product-buy-box-kids"]');
  if (!section) return;

  /* Gallery */
  var images = section.querySelectorAll('[data-gallery-img]');
  var dots = section.querySelectorAll('[data-gallery-dot]');
  var thumbs = section.querySelectorAll('[data-thumb]');
  var firstTags = section.querySelectorAll('[data-first-image-tag]');
  var overlay3pack = section.querySelector('[data-overlay-3pack]');
  var overlayBefore = section.querySelector('[data-overlay-before]');
  var overlayAfter = section.querySelector('[data-overlay-after]');
  var galleryNames = ['product-kids-patches-v2.jpg','before-after-no-labels.jpg','kids-3pack-forest.jpg','kids-pack-moss.jpg','kids-lifestyle-stickers.webp'];
  var currentImg = 0;
  var total = images.length;

  function showImage(idx) {
    currentImg = ((idx % total) + total) % total;
    images.forEach(function(img, i) { img.classList.toggle('luna-buy-box__gallery-img--active', i === currentImg); });
    dots.forEach(function(dot, i) { dot.classList.toggle('luna-buy-box__dot--active', i === currentImg); });
    thumbs.forEach(function(thumb, i) { thumb.classList.toggle('luna-buy-box__thumb--active', i === currentImg); });
    firstTags.forEach(function(el) { el.style.display = currentImg === 0 ? '' : 'none'; });
    var is3pack = galleryNames[currentImg] && galleryNames[currentImg].indexOf('3pack') !== -1;
    overlay3pack.classList.toggle('luna-buy-box__overlay-3pack--visible', is3pack);
    var isBA = galleryNames[currentImg] && galleryNames[currentImg].indexOf('before-after') !== -1;
    overlayBefore.classList.toggle('luna-buy-box__before-label--visible', isBA);
    overlayAfter.classList.toggle('luna-buy-box__after-label--visible', isBA);
  }

  section.querySelector('[data-gallery-prev]').addEventListener('click', function() { showImage(currentImg - 1); });
  section.querySelector('[data-gallery-next]').addEventListener('click', function() { showImage(currentImg + 1); });
  dots.forEach(function(dot) { dot.addEventListener('click', function() { showImage(parseInt(this.getAttribute('data-gallery-dot'))); }); });
  thumbs.forEach(function(thumb) { thumb.addEventListener('click', function() { showImage(parseInt(this.getAttribute('data-thumb'))); }); });

  /* Info tabs */
  var tabBtns = section.querySelectorAll('[data-info-tab]');
  var panels = section.querySelectorAll('[data-info-panel]');
  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = this.getAttribute('data-info-tab');
      tabBtns.forEach(function(b) { b.classList.toggle('luna-buy-box__info-tab-btn--active', b.getAttribute('data-info-tab') === key); });
      panels.forEach(function(p) { p.classList.toggle('luna-buy-box__info-panel--active', p.getAttribute('data-info-panel') === key); });
    });
  });

  /* Bundle selector */
  var bundleBtns = section.querySelectorAll('[data-bundle]');
  var offerType = 'subscribe';
  var bundleSize = 2;
  var subPrice = 9.99, subCompare = 24.99, patchCount = 120;
  var bundleData = { 2: { priceEach: 12.99, compareEach: 24.99 }, 4: { priceEach: 8.99, compareEach: 24.99 } };

  function updatePrices() {
    var bd = bundleData[bundleSize];
    var onetimePrice = bd.priceEach * bundleSize;
    var onetimeCompare = bd.compareEach * bundleSize;
    var price = offerType === 'subscribe' ? subPrice : onetimePrice;
    var compare = offerType === 'subscribe' ? subCompare : onetimeCompare;
    var discount = Math.round(((compare - price) / compare) * 100);
    var perPatch = (offerType === 'subscribe' ? subPrice : bd.priceEach) / patchCount;

    var pc = section.querySelector('[data-price-compare]');
    var pcur = section.querySelector('[data-price-current]');
    var pp = section.querySelector('[data-per-patch]');
    var ctaMain = section.querySelector('.luna-buy-box__cta-main');
    var ctaPrice = section.querySelector('[data-cta-price]');
    var ctaCompare = section.querySelector('[data-cta-compare]');

    if (pc) pc.textContent = '$' + compare.toFixed(2);
    if (pcur) pcur.textContent = '$' + price.toFixed(2);
    if (pp) pp.textContent = '$' + perPatch.toFixed(2) + '/patch \u00b7 ' + patchCount + ' patches per pack';
    if (ctaMain) ctaMain.textContent = 'Claim deal \u00b7 Save ' + discount + '%';
    if (ctaPrice) ctaPrice.textContent = '$' + price.toFixed(2);
    if (ctaCompare) ctaCompare.textContent = '$' + compare.toFixed(2);

    var threshold = 30;
    var remaining = Math.max(0, threshold - price);
    var pct = Math.min(100, Math.round((price / threshold) * 100));
    var qualified = remaining <= 0;
    var msgEl = section.querySelector('.luna-buy-box__free-ship-msg');
    var pctEl = section.querySelector('.luna-buy-box__free-ship-pct');
    var fillEl = section.querySelector('.luna-buy-box__free-ship-fill');
    if (msgEl) {
      msgEl.innerHTML = qualified
        ? '<span class="green-bold">You qualify for free shipping!</span>'
        : 'You\'re <span class="accent">$' + remaining.toFixed(2) + '</span> from free shipping';
    }
    if (pctEl) pctEl.textContent = pct + '%';
    if (fillEl) {
      fillEl.style.width = pct + '%';
      fillEl.className = 'luna-buy-box__free-ship-fill ' + (qualified ? 'luna-buy-box__free-ship-fill--green' : 'luna-buy-box__free-ship-fill--accent');
    }
  }

  bundleBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      bundleSize = parseInt(this.getAttribute('data-bundle'));
      bundleBtns.forEach(function(b) { b.classList.toggle('luna-buy-box__bundle--active', parseInt(b.getAttribute('data-bundle')) === bundleSize); });
      updatePrices();
    });
  });

  /* Subscribe toggle */
  var subToggle = section.querySelector('[data-subscribe-toggle]');
  var subContainer = section.querySelector('[data-subscribe]');
  if (subToggle) {
    subToggle.addEventListener('click', function() {
      offerType = offerType === 'subscribe' ? 'onetime' : 'subscribe';
      this.classList.toggle('luna-buy-box__toggle--on', offerType === 'subscribe');
      subContainer.classList.toggle('luna-buy-box__subscribe--active', offerType === 'subscribe');
      updatePrices();
    });
  }

  /* Countdown */
  var countdownEl = section.querySelector('[data-countdown]');
  if (countdownEl) {
    var hrs = 5, min = 11, sec = 26;
    function pad(n) { return String(n).padStart(2, '0'); }
    setInterval(function() {
      sec--;
      if (sec < 0) { sec = 59; min--; }
      if (min < 0) { min = 59; hrs--; }
      if (hrs < 0) { hrs = 0; min = 0; sec = 0; }
      countdownEl.textContent = pad(hrs) + 'h ' + pad(min) + 'm ' + pad(sec) + 's';
    }, 1000);
  }
})();
</script>

{% schema %}
{
  "name": "Luna Kids Buy Box",
  "tag": "section",
  "class": "luna-product-buy-box-kids",
  "settings": []
}
{% endschema %}
