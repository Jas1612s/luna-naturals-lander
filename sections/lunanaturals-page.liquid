<script>
(function() {
  /* ── Pack Selector ── */
  var packCards = document.querySelectorAll('[data-pack-size]');
  if (!packCards.length) {
    packCards = document.querySelectorAll('.pack-card, [class*="pack"]');
  }
  
  /* ── FAQ Accordion ── */
  document.querySelectorAll('[data-faq-trigger], .faq-question, details summary').forEach(function(trigger) {
    trigger.addEventListener('click', function(e) {
      var answer = this.nextElementSibling;
      if (answer) {
        var isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';
        answer.style.maxHeight = isOpen ? '0px' : answer.scrollHeight + 'px';
        answer.style.overflow = 'hidden';
        answer.style.transition = 'max-height 0.3s ease';
        this.classList.toggle('open');
      }
    });
  });

  /* ── Countdown Timer ── */
  var countdownEls = document.querySelectorAll('[class*="countdown"], [data-countdown]');
  if (countdownEls.length) {
    var endTime = Date.now() + 4 * 60 * 60 * 1000;
    function updateCountdown() {
      var remaining = endTime - Date.now();
      if (remaining <= 0) return;
      var h = Math.floor(remaining / 3600000);
      var m = Math.floor((remaining % 3600000) / 60000);
      var s = Math.floor((remaining % 60000) / 1000);
      var text = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
      countdownEls.forEach(function(el) { el.textContent = text; });
      requestAnimationFrame(updateCountdown);
    }
    updateCountdown();
  }

  /* ── Gallery Image Swipe ── */
  var galleries = document.querySelectorAll('[class*="gallery"], [class*="product-image"]');
  var thumbs = document.querySelectorAll('[class*="thumbnail"]');
  var mainImg = document.querySelector('[class*="main-image"] img, [class*="gallery"] > img');
  if (thumbs.length && mainImg) {
    thumbs.forEach(function(thumb, i) {
      thumb.addEventListener('click', function() {
        var src = this.querySelector('img') ? this.querySelector('img').src : this.dataset.src;
        if (src) mainImg.src = src;
        thumbs.forEach(function(t) { t.classList.remove('active'); });
        this.classList.add('active');
      });
    });
  }

  /* ── Touch Swipe for Carousels ── */
  document.querySelectorAll('[class*="carousel"], [style*="overflow-x"], [class*="scroll"]').forEach(function(carousel) {
    var startX, scrollLeft;
    carousel.addEventListener('touchstart', function(e) {
      startX = e.touches[0].pageX;
      scrollLeft = carousel.scrollLeft;
    }, { passive: true });
    carousel.addEventListener('touchmove', function(e) {
      if (!startX) return;
      var x = e.touches[0].pageX;
      carousel.scrollLeft = scrollLeft - (x - startX);
    }, { passive: true });
    carousel.addEventListener('touchend', function() { startX = null; });
  });

  /* ── Lazy Video Autoplay ── */
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      var video = entry.target;
      if (entry.isIntersecting) {
        video.play().catch(function(){});
      } else {
        video.pause();
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('video[autoplay]').forEach(function(v) { observer.observe(v); });

  /* ── Smooth Scroll for Anchor Links ── */
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  /* ── Mobile Menu Toggle ── */
  var menuBtn = document.querySelector('[class*="mobile-menu"], [class*="hamburger"], [aria-label*="menu"]');
  var mobileMenu = document.querySelector('nav[class*="mobile"], [class*="mobile-nav"]');
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', function() {
      mobileMenu.classList.toggle('open');
      mobileMenu.style.display = mobileMenu.classList.contains('open') ? 'block' : 'none';
    });
  }

  /* ── Sticky Mobile CTA ── */
  var stickyCTA = document.querySelector('[class*="sticky-cta"], [class*="sticky-mobile"]');
  if (stickyCTA) {
    window.addEventListener('scroll', function() {
      stickyCTA.style.opacity = window.scrollY > 600 ? '1' : '0';
      stickyCTA.style.pointerEvents = window.scrollY > 600 ? 'auto' : 'none';
      stickyCTA.style.transition = 'opacity 0.3s';
    }, { passive: true });
  }
})();
</script>
